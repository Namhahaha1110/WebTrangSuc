    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ── Announcement bar hide on scroll ──────────────────────────
        (function () {
            const bar    = document.getElementById('announcementBar');
            const navbar = document.getElementById('siteNavbar');
            if (!bar) return;
            let lastY = 0;
            window.addEventListener('scroll', function () {
                const y = window.scrollY;
                if (y > 80 && y > lastY) {
                    bar.classList.add('hidden');
                } else if (y < 40) {
                    bar.classList.remove('hidden');
                }
                lastY = y;
                // Navbar shadow on scroll
                if (navbar) navbar.classList.toggle('scrolled', y > 10);
            }, { passive: true });
        })();

        // ── Hero Slideshow v2 — fixed dots, no transform glitch, swipe support ──
        (function () {
            const container = document.getElementById('heroSlideshow');
            if (!container) return;

            /* Use updated selector: .hero-dot-btn (pip design) */
            const slides  = Array.from(container.querySelectorAll('.hero-slide'));
            const dotBtns = Array.from(container.querySelectorAll('.hero-dot-btn'));
            const btnPrev = document.getElementById('heroPrev');
            const btnNext = document.getElementById('heroNext');
            if (!slides.length) return;

            let index = 0;
            let timer;
            const INTERVAL   = 5000;
            const prefersRed = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            function showSlide(i) {
                slides.forEach((s, idx) => {
                    const wasActive = s.classList.contains('active');
                    s.classList.toggle('active', idx === i);
                    /* Remove animation so Ken Burns resets cleanly on re-activation */
                    if (!wasActive && idx === i) {
                        s.style.animation = 'none';
                        /* Force reflow to restart animation */
                        s.offsetWidth; // eslint-disable-line no-unused-expressions
                        s.style.animation = '';
                    }
                });
                dotBtns.forEach((d, idx) => {
                    d.classList.toggle('active', idx === i);
                    d.setAttribute('aria-pressed', idx === i ? 'true' : 'false');
                });
                index = i;
            }

            function next() { showSlide((index + 1) % slides.length); }
            function prev() { showSlide((index - 1 + slides.length) % slides.length); }

            function start() {
                if (prefersRed || slides.length < 2) return;
                stop();
                timer = setInterval(next, INTERVAL);
            }
            function stop() { clearInterval(timer); }

            /* Dot clicks */
            dotBtns.forEach((d, i) => {
                d.addEventListener('click', () => { showSlide(i); start(); });
            });

            /* Arrow clicks */
            if (btnPrev) btnPrev.addEventListener('click', () => { prev(); start(); });
            if (btnNext) btnNext.addEventListener('click', () => { next(); start(); });

            /* Pause on hover/focus */
            container.addEventListener('mouseenter', stop);
            container.addEventListener('mouseleave', start);
            container.addEventListener('focusin',  stop);
            container.addEventListener('focusout', start);

            /* Touch swipe support — mobile UX */
            let touchX = 0;
            container.addEventListener('touchstart', e => {
                touchX = e.changedTouches[0].clientX;
            }, { passive: true });
            container.addEventListener('touchend', e => {
                const dx = e.changedTouches[0].clientX - touchX;
                if (Math.abs(dx) > 40) {
                    dx < 0 ? next() : prev();
                    start();
                }
            }, { passive: true });

            /* Keyboard navigation */
            container.addEventListener('keydown', e => {
                if (e.key === 'ArrowLeft')  { prev(); start(); }
                if (e.key === 'ArrowRight') { next(); start(); }
            });

            showSlide(0);
            start();
        })();

        // ── Chat Widget ───────────────────────────────────────────────
        (function () {
            const icon      = document.getElementById('chatIcon');
            const box       = document.getElementById('chatBox');
            const closeBtn  = document.getElementById('closeChat');
            const sendBtn   = document.getElementById('sendButton');
            const input     = document.getElementById('messageInput');
            const msgList   = document.getElementById('messagesList');
            if (!icon || !box) return;

            let greetingSent = false;

            function openChat() {
                box.style.display = 'block';
                icon.setAttribute('aria-expanded', 'true');
                icon.style.display = 'none';
                if (!greetingSent) {
                    renderMessage('Flower Jewelry',
                        'Flower Jewelry xin chào!\nChúng tôi có thể hỗ trợ gì cho bạn hôm nay?');
                    greetingSent = true;
                }
                input.focus();
            }
            function closeChat() {
                box.style.display = 'none';
                icon.style.display = 'flex';
                icon.setAttribute('aria-expanded', 'false');
                icon.focus();
            }

            icon.addEventListener('click', openChat);
            closeBtn.addEventListener('click', closeChat);

            // Escape key to close
            box.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') closeChat();
            });

            function renderMessage(user, message) {
                const wrap   = document.createElement('div');
                const bubble = document.createElement('div');
                const isUser = user === 'Bạn';

                Object.assign(wrap.style, {
                    display:        'flex',
                    justifyContent: isUser ? 'flex-end' : 'flex-start',
                });
                Object.assign(bubble.style, {
                    maxWidth:     '75%',
                    padding:      '10px 14px',
                    borderRadius: isUser ? '16px 16px 4px 16px' : '16px 16px 16px 4px',
                    fontSize:     '14px',
                    lineHeight:   '1.55',
                    whiteSpace:   'pre-wrap',
                    background:   isUser ? 'linear-gradient(135deg,#A16207,#D4AF37)' : '#F0EFED',
                    color:        isUser ? 'white' : '#1C1917',
                });

                bubble.textContent = message;
                wrap.appendChild(bubble);
                msgList.appendChild(wrap);
                msgList.scrollTop = msgList.scrollHeight;
            }

            // Send on button click or Enter
            function sendMsg() {
                const msg = input.value.trim();
                if (!msg) return;
                renderMessage('Bạn', msg);
                if (typeof connection !== 'undefined') {
                    connection.invoke('SendMessage', 'Bạn', msg).catch(console.error);
                }
                input.value = '';
                input.focus();
            }

            sendBtn.addEventListener('click', sendMsg);
            input.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMsg(); }
            });
        })();
    </script>

    <!-- SIGNALR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl('/chathub')
            .build();

        connection.on('ReceiveMessage', function (user, message) {
            const msgList = document.getElementById('messagesList');
            if (!msgList) return;
            const wrap   = document.createElement('div');
            const bubble = document.createElement('div');
            const isUser = user === 'Bạn';
            Object.assign(wrap.style, { display: 'flex', justifyContent: isUser ? 'flex-end' : 'flex-start' });
            Object.assign(bubble.style, {
                maxWidth: '75%', padding: '10px 14px', fontSize: '14px',
                lineHeight: '1.55', whiteSpace: 'pre-wrap',
                borderRadius: isUser ? '16px 16px 4px 16px' : '16px 16px 16px 4px',
                background: isUser ? 'linear-gradient(135deg,#A16207,#D4AF37)' : '#F0EFED',
                color: isUser ? 'white' : '#1C1917',
            });
            bubble.textContent = message;
            wrap.appendChild(bubble);
            msgList.appendChild(wrap);
            msgList.scrollTop = msgList.scrollHeight;
        });

        connection.start().catch(err => console.error('SignalR Error:', err));
    </script>

    @RenderSection("Scripts", required: false)
</body>

                    </div>
                    
                    <div class="voucher-form" id="voucherForm">
                        <input type="text" class="voucher-input" id="voucherCode" placeholder="Nhập mã (VD: LUXURY25)" />
                        <button type="button" class="btn-voucher" id="btnApplyVoucher" aria-label="Áp dụng mã giảm giá">ÁP DỤNG</button>
                    </div>

                    <div class="voucher-applied" id="voucherApplied">
                        <div class="voucher-applied-info">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            <span id="appliedVoucherCode">LUXURY25</span>
                        </div>
                        <button type="button" class="btn-remove-voucher" id="btnRemoveVoucher" aria-label="Hủy mã giảm giá">
                             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <button type="submit" form="checkoutForm" class="btn-order">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                    </svg>
                    Đặt hàng ngay
                </button>

                <p class="summary-note">
                    🔒 Thông tin của bạn được bảo mật tuyệt đối.<br>
                    Chính sách đổi trả trong vòng 7 ngày.
                </p>
            </div>
        </aside>
    </div>
}

<!-- TOAST CONTAINER -->
<div id="toastContainer" class="toast-container" aria-live="polite" aria-atomic="true"></div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    /* ── TOAST ──────────────────────────────────────── */
    function showToast(type, title, msg) {
        const container = document.getElementById('toastContainer');
        if (!container) return;
        const icons = {
            success: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
            error:   `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`,
        };
        const toast = document.createElement('div');
        toast.className = `toast toast--${type}`;
        toast.setAttribute('role', 'alert');
        toast.innerHTML = `<span>${icons[type] || ''}</span><div class="toast__msg"><strong>${title}</strong>${msg ? msg : ''}</div>`;
        container.appendChild(toast);
        setTimeout(() => {
            toast.style.animation = 'toastOut 250ms ease-in forwards';
            setTimeout(() => toast.remove(), 260);
        }, 3500);
    }

    /* ── VALIDATION ERRORS ──────────────────────────── */
    function showValidationErrors(errors) {
        const el = document.getElementById('formErrors');
        if (!el) return;
        el.innerHTML = `<div class="form-errors__title">Vui lòng kiểm tra lại:</div><ul>${errors.map(e => `<li>${e}</li>`).join('')}</ul>`;
        el.style.display = 'block';
        el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    function clearValidationErrors() {
        const el = document.getElementById('formErrors');
        if (el) { el.innerHTML = ''; el.style.display = 'none'; }
    }

    /* ── BUSINESS LOGIC (kept from original) ────────── */
    let locationData = [];
    let storesData = {};
    let formData = {
        delivery: { province: "", district: "", ward: "", addressDetail: "" },
        pickup:   { city: "", district: "", store: "" }
    };

    function saveDeliveryData() {
        formData.delivery.province      = $("#province").val();
        formData.delivery.district      = $("#district").val();
        formData.delivery.ward          = $("#ward").val();
        formData.delivery.addressDetail = $("#addressDetail").val();
    }
    function savePickupData() {
        formData.pickup.city     = $("#citySelect").val();
        formData.pickup.district = $("#districtSelect").val();
        formData.pickup.store    = $("#storeSelect").val();
    }
    function restoreDeliveryData() {
        if (!formData.delivery.province) return;
        $("#province").val(formData.delivery.province);
        onProvinceChange();
        setTimeout(() => {
            $("#district").val(formData.delivery.district);
            onDistrictChange();
            $("#ward").val(formData.delivery.ward);
            $("#addressDetail").val(formData.delivery.addressDetail);
        }, 100);
    }
    function restorePickupData() {
        if (!formData.pickup.city) return;
        $("#citySelect").val(formData.pickup.city);
        onCityChange();
        setTimeout(() => {
            $("#districtSelect").val(formData.pickup.district);
            onPickupDistrictChange();
            $("#storeSelect").val(formData.pickup.store);
        }, 100);
    }
    function loadProvinces() {
        return fetch('/data/vietnam-provinces.json')
            .then(res => res.json())
            .then(data => {
                locationData = data;
                const provinceSelect = $("#province");
                provinceSelect.html('<option value="">Chọn tỉnh/thành *</option>');
                data.forEach(p => provinceSelect.append(`<option value="${p.name}">${p.name}</option>`));
            })
            .catch(err => console.error("[Cart] Error loading provinces:", err));
    }
    function applyInitialDeliveryPrefill() {
        const province = ($("#province").data("prefill") || "").toString().trim();
        const district = ($("#district").data("prefill") || "").toString().trim();
        const ward     = ($("#ward").data("prefill") || "").toString().trim();
        if (!province) return;
        $("#province").val(province);
        onProvinceChange();
        if (district) {
            setTimeout(() => {
                $("#district").val(district);
                onDistrictChange();
                if (ward) setTimeout(() => $("#ward").val(ward), 120);
            }, 120);
        }
    }
    function onProvinceChange() {
        const provinceName = $("#province").val();
        const districtSelect = $("#district");
        districtSelect.html('<option value="">Chọn quận/huyện *</option>');
        districtSelect.prop('disabled', false);
        $("#ward").html('<option value="">Chọn phường/xã *</option>');
        $("#ward").prop('disabled', false);
        if (!provinceName) { districtSelect.prop('disabled', true); return; }
        const province = locationData.find(p => p.name === provinceName);
        if (province && province.districts && province.districts.length > 0) {
            province.districts.forEach(d => districtSelect.append(`<option value="${d.name}">${d.name}</option>`));
        } else { districtSelect.prop('disabled', true); }
    }
    function onDistrictChange() {
        const provinceName = $("#province").val();
        const districtName = $("#district").val();
        const wardSelect = $("#ward");
        wardSelect.html('<option value="">Chọn phường/xã *</option>');
        wardSelect.prop('disabled', false);
        if (!provinceName || !districtName) { wardSelect.prop('disabled', true); return; }
        const province = locationData.find(p => p.name === provinceName);
        if (province && province.districts) {
            const district = province.districts.find(d => d.name === districtName);
            if (district && district.wards && district.wards.length > 0) {
                district.wards.forEach(w => wardSelect.append(`<option value="${w.name}">${w.name}</option>`));
            } else { wardSelect.prop('disabled', true); }
        }
    }
    function loadStores() {
        fetch('/data/stores.json')
            .then(res => res.json())
            .then(data => { storesData = data; })
            .catch(err => console.error("[Cart] Error loading stores:", err));
    }
    function getCityStoreConfig(city) {
        if (!city || !storesData || !storesData[city]) return null;
        const rawCityData = storesData[city];
        if (rawCityData && rawCityData.districts && rawCityData.branches) {
            return {
                districts: rawCityData.districts,
                getStoresByDistrict: function(district) {
                    return (rawCityData.branches[district] || []).map((address, i) => ({
                        id: `${city}-${district}-${i+1}`, name: `Chi nhánh ${i+1}`, address
                    }));
                }
            };
        }
        if (Array.isArray(rawCityData)) {
            return {
                districts: [...new Set(rawCityData.map(s => s.district))],
                getStoresByDistrict: district => rawCityData.filter(s => s.district === district)
            };
        }
        return null;
    }
    function onCityChange() {
        const city = $("#citySelect").val();
        const districtSelect = $("#districtSelect");
        const storeSelect = $("#storeSelect");
        districtSelect.html('<option value="">— Chọn Quận/Huyện —</option>');
        storeSelect.html('<option value="">— Chọn Cửa Hàng —</option>');
        storeSelect.prop('disabled', true);
        const cfg = getCityStoreConfig(city);
        if (!cfg) { districtSelect.prop('disabled', true); return; }
        cfg.districts.forEach(d => districtSelect.append(`<option value="${d}">${d}</option>`));
        districtSelect.prop('disabled', false);
    }
    function onPickupDistrictChange() {
        const city = $("#citySelect").val();
        const district = $("#districtSelect").val();
        const storeSelect = $("#storeSelect");
        storeSelect.html('<option value="">— Chọn Cửa Hàng —</option>');
        const cfg = getCityStoreConfig(city);
        if (!district || !cfg) { storeSelect.prop('disabled', true); return; }
        const stores = cfg.getStoresByDistrict(district);
        stores.forEach(s => {
            const val   = s.address || s.id || "";
            const label = s.address ? `${s.name} - ${s.address}` : (s.name || val);
            storeSelect.append(`<option value="${val}" data-address="${s.address||''}">${label}</option>`);
        });
        storeSelect.prop('disabled', stores.length === 0);
    }
    let currentVoucher = null;
    const VOUCHER_DISCOUNT_PERCENT = 0.1; // Demo mã giảm 10%
    
    function updateTotal() {
        let total = 0;
        $(".product-item").each(function () {
            if ($(this).find(".product-checkbox").is(":checked")) {
                const priceText = $(this).find(".product-price").text().replace(/[^\d]/g, "");
                total += parseInt(priceText) || 0;
            }
        });
        
        let discount = 0;
        if (currentVoucher) {
            discount = total * VOUCHER_DISCOUNT_PERCENT;
        }
        
        const finalTotal = total - discount;
        
        $("#subtotal").text(total.toLocaleString("vi-VN") + " VNĐ");
        
        if (discount > 0) {
            $("#discountVal").text("- " + discount.toLocaleString("vi-VN") + " VNĐ");
            $("#discountRow").css('display', 'flex');
        } else {
            $("#discountRow").hide();
        }
        
        $("#total").text(finalTotal.toLocaleString("vi-VN") + " VNĐ");
    }
    function updateQuantity(productId, quantity) {
        const token = $('input[name="__RequestVerificationToken"]').val();
        $.post("/Cart?handler=UpdateQuantity", { __RequestVerificationToken: token, productId, quantity })
        .done(function(res) {
            const fmt = res.total.toLocaleString("vi-VN") + " VNĐ";
            $("#subtotal").text(fmt);
            $("#total").text(fmt);
        })
        .fail(function(xhr) {
            showToast('error', 'Lỗi cập nhật số lượng', xhr.responseJSON?.message || 'Vui lòng thử lại.');
        });
    }

    /* ── EVENT LISTENERS ─────────────────────────────── */
    $(document).ready(function () {
        loadProvinces().then(() => applyInitialDeliveryPrefill());
        loadStores();

        $(document).on("change", "#province",      () => onProvinceChange());
        $(document).on("change", "#district",      () => onDistrictChange());
        $(document).on("change", "#citySelect",    () => onCityChange());
        $(document).on("change", "#districtSelect",() => onPickupDistrictChange());

        /* Quantity buttons */
        $(document).on("click", ".quantity-btn", function () {
            const $btn  = $(this);
            const $input = $btn.siblings(".quantity-input");
            const $item  = $btn.closest(".product-item");
            const $price = $item.find(".product-price");
            const base   = parseInt($price.attr("data-base-price"));
            let qty      = parseInt($input.val());
            if ($btn.attr("data-action") === "add") qty++;
            else if (qty > 1) qty--;
            $input.val(qty);
            $price.text((qty * base).toLocaleString("vi-VN") + " VNĐ");
            updateTotal();
            updateQuantity($input.data("product-id"), qty);
        });

        /* Quantity input change */
        $(document).on("change", ".quantity-input", function () {
            const $input = $(this);
            const $item  = $input.closest(".product-item");
            const $price = $item.find(".product-price");
            const base   = parseInt($price.attr("data-base-price"));
            let qty      = parseInt($input.val()) || 1;
            if (qty < 1) qty = 1;
            $input.val(qty);
            $price.text((qty * base).toLocaleString("vi-VN") + " VNĐ");
            updateTotal();
            updateQuantity($input.data("product-id"), qty);
        });

        /* Checkbox change */
        $(document).on("change", ".product-checkbox", () => updateTotal());

        /* Delete item */
        $(document).on("click", ".btn-delete", function () {
            const $item     = $(this).closest(".product-item");
            const productId = $(this).data("product-id");
            const token     = $('input[name="__RequestVerificationToken"]').val();
            $.post("/Cart?handler=RemoveLine", { __RequestVerificationToken: token, productId }, function (res) {
                if (res.success) {
                    $item.fadeOut(250, function () { $(this).remove(); updateTotal(); });
                    showToast('success', 'Đã xóa sản phẩm', '');
                }
            }).fail(() => showToast('error', 'Lỗi khi xóa sản phẩm', 'Vui lòng thử lại.'));
        });

        /* Delivery toggle */
        $("#btnDelivery").click(function (e) {
            e.preventDefault();
            savePickupData();
            $(this).addClass("active").attr("aria-pressed", "true");
            $("#btnPickup").removeClass("active").attr("aria-pressed", "false");
            $("#pickupForm").hide();
            $("#deliveryForm").show();
            $("#deliveryTypeInput").val("delivery");
            restoreDeliveryData();
        });
        $("#btnPickup").click(function (e) {
            e.preventDefault();
            saveDeliveryData();
            $(this).addClass("active").attr("aria-pressed", "true");
            $("#btnDelivery").removeClass("active").attr("aria-pressed", "false");
            $("#deliveryForm").hide();
            $("#pickupForm").show();
            $("#deliveryTypeInput").val("pickup");
            restorePickupData();
        });

        /* Voucher Logic */
        $("#btnApplyVoucher").click(function() {
            const code = $("#voucherCode").val().trim().toUpperCase();
            if (!code) {
                showToast('error', 'Cảnh báo', 'Vui lòng nhập mã giảm giá');
                return;
            }
            // Giả lập call API check voucher
            currentVoucher = code;
            
            $("#voucherForm").hide();
            $("#appliedVoucherCode").text(code);
            $("#voucherApplied").css('display', 'flex');
            
            updateTotal();
            showToast('success', 'Áp dụng thành công', `Giảm 10% tổng đơn hàng (Mã: ${code})`);
        });
        
        $("#btnRemoveVoucher").click(function() {
            currentVoucher = null;
            $("#voucherApplied").hide();
            $("#voucherForm").show();
            $("#voucherCode").val('');
            
            updateTotal();
            showToast('success', 'Đã hủy mã giảm giá');
        });

        /* Form submit — consolidated validation */
        $("#checkoutForm").on("submit", function (e) {
            clearValidationErrors();

            const deliveryType = $("#deliveryTypeInput").val();
            const errors = [];

            if (!$('input[name="Name"]').val().trim())  errors.push("Tên người mua không được để trống");
            if (!$('input[name="Phone"]').val().trim())  errors.push("Số điện thoại không được để trống");
            if (!$('input[name="Email"]').val().trim())  errors.push("Email không được để trống");

            const hasChecked = $(".product-checkbox:checked").length > 0;
            if (!hasChecked) errors.push("Vui lòng chọn ít nhất 1 sản phẩm");

            if (deliveryType === "delivery") {
                if (!$("#province").val())             errors.push("Vui lòng chọn Tỉnh/Thành");
                if (!$("#district").val())             errors.push("Vui lòng chọn Quận/Huyện");
                if (!$("#ward").val())                 errors.push("Vui lòng chọn Phường/Xã");
                if (!$("#addressDetail").val().trim()) errors.push("Vui lòng nhập địa chỉ cụ thể");
            } else if (deliveryType === "pickup") {
                if (!$("#citySelect").val())           errors.push("Vui lòng chọn Thành Phố");
                if (!$("#districtSelect").val())       errors.push("Vui lòng chọn Quận/Huyện");
                if (!$("#storeSelect").val())          errors.push("Vui lòng chọn Cửa Hàng");
            }

            if (errors.length > 0) {
                e.preventDefault();
                showValidationErrors(errors);
                return false;
            }

            /* Append payment method */
            const paymentMethod = $('input[name="Payment"]:checked').val();
            $(this).append(`<input type="hidden" name="payment" value="${paymentMethod}">`);
        });
    });
</script>

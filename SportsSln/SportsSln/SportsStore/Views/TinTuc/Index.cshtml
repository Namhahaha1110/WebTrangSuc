            <tr><td>N.Tròn, 3A, Đ.Vàng T.Bình</td><td>150,030,000</td><td>150,300,000</td></tr>
            <tr><td>N.Tròn, 3A, Đ.Vàng N.An</td><td>150,040,000</td><td>150,310,000</td></tr>

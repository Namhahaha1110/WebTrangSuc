@page
@model SportsStore.Pages.PaymentPendingModel
@{
    ViewData["Title"] = "Thanh toán VNPAY";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4 mb-5" style="max-width: 720px;">
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <h3 class="mb-3" style="color:#b8860b;">Thanh toán online qua VNPAY</h3>

            @if (Model.CurrentOrder != null)
            {
                <p class="mb-1"><strong>Đơn hàng:</strong> #@Model.CurrentOrder.OrderID</p>
                <p class="mb-1"><strong>Tổng tiền:</strong> @Model.CurrentOrder.TotalPrice.ToString("#,##0") VND</p>
                <p class="mb-3 text-muted">@Model.Message</p>

                <div id="paymentInfo" class="alert alert-warning">Đang khởi tạo giao dịch VNPAY...</div>

                <button id="btnPayVnpay" type="button" class="btn btn-primary w-100">Tiếp tục thanh toán với VNPAY</button>
                <small class="d-block mt-2 text-muted">Bạn sẽ được chuyển sang cổng VNPAY để hoàn tất giao dịch bảo mật.</small>

                <a class="btn btn-outline-secondary w-100 mt-2" href="/customer/my-orders">Theo dõi đơn hàng</a>
            }
            else
            {
                <div class="alert alert-warning mb-0">Không tìm thấy đơn hàng để thanh toán.</div>
            }
        </div>
    </div>
</div>

@if (Model.CurrentOrder != null)
{
    <script>
        const apiOrderCode = "@Model.ApiOrderCode";
        const orderId = @Model.CurrentOrder.OrderID;
        const paymentInfo = document.getElementById("paymentInfo");
        const payButton = document.getElementById("btnPayVnpay");

        async function startVnpayPayment() {
            if (!payButton) return;

            payButton.disabled = true;
            paymentInfo.className = "alert alert-warning";
            paymentInfo.innerText = "Đang tạo đường dẫn thanh toán VNPAY...";

            try {
                const response = await fetch(`/api/payment/vnpay/create-url?orderId=${orderId}`);
                const data = await response.json();

                if (!response.ok || !data.success) {
                    throw new Error(data.message || "Không thể khởi tạo thanh toán VNPAY");
                }

                paymentInfo.className = "alert alert-info";
                paymentInfo.innerText = "Đang chuyển sang cổng thanh toán VNPAY...";
                window.location.href = data.paymentUrl;
            } catch (error) {
                payButton.disabled = false;
                paymentInfo.className = "alert alert-danger";
                paymentInfo.innerText = error.message;
            }
        }

        async function checkPaymentStatus() {
            try {
                const response = await fetch(`/api/payment/status?orderId=${encodeURIComponent(apiOrderCode)}`);
                const data = await response.json();

                if (response.ok && data.success && data.isPaid) {
                    paymentInfo.className = "alert alert-success";
                    paymentInfo.innerText = "Hệ thống đã ghi nhận thanh toán. Đang chuyển trang...";
                    window.location.href = `/Completed?orderId=${orderId}`;
                }
            } catch {
                // Bỏ qua lỗi tạm thời khi polling
            }
        }

        if (payButton) {
            payButton.addEventListener("click", startVnpayPayment);
        }

        setInterval(checkPaymentStatus, 3000);
    </script>
}

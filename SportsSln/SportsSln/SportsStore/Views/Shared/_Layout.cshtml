@* Views/Shared/_Layout.cshtml — Flower Jewelry Luxury Redesign *@
@inject SportsStore.Models.IStoreRepository StoreRepository
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Flower Jewelry — Trang sức tinh xảo, chất lượng cao cấp, thiết kế sang trọng." />
    <title>@ViewData["Title"] - Flower Jewelry</title>

    <!-- PRELOAD critical font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
    <!-- FONT AWESOME -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />
    <!-- GOOGLE FONTS — Cormorant (heading) + Montserrat (body) -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        /* ============================================================
           DESIGN TOKENS — Flower Jewelry Luxury System
           ============================================================ */
        :root {
            /* Brand Colors */
            --color-primary:        #1C1917;
            --color-on-primary:     #FFFFFF;
            --color-secondary:      #44403C;
            --color-accent:         #A16207;
            --color-accent-light:   #D4AF37;
            --color-accent-hover:   #B8961F;
            --color-background:     #FAFAF9;
            --color-surface:        rgba(255, 255, 255, 0.90);
            --color-foreground:     #0C0A09;
            --color-muted:          #E8ECF0;
            --color-border:         #D6D3D1;
            --color-border-subtle:  #EDEBE9;
            --color-destructive:    #DC2626;
            --color-text-secondary: #78716C;

            /* Typography */
            --font-heading: 'Cormorant', Georgia, 'Times New Roman', serif;
            --font-body:    'Montserrat', system-ui, -apple-system, sans-serif;

            /* Spacing — 4dp base scale */
            --space-1:  4px;
            --space-2:  8px;
            --space-3:  12px;
            --space-4:  16px;
            --space-5:  20px;
            --space-6:  24px;
            --space-8:  32px;
            --space-10: 40px;
            --space-12: 48px;
            --space-16: 64px;
            --space-20: 80px;

            /* Border Radius */
            --radius-sm:   4px;
            --radius-md:   8px;
            --radius-lg:   12px;
            --radius-xl:   20px;
            --radius-full: 9999px;

            /* Elevation */
            --shadow-sm:  0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
            --shadow-md:  0 4px 12px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
            --shadow-lg:  0 8px 32px rgba(0,0,0,0.10), 0 4px 8px rgba(0,0,0,0.06);
            --shadow-xl:  0 20px 60px rgba(0,0,0,0.14);
            --shadow-gold: 0 4px 20px rgba(161, 98, 7, 0.25);

            /* Z-Index Scale */
            --z-base:    0;
            --z-card:   10;
            --z-overlay: 20;
            --z-sticky:  40;
            --z-modal:  100;
            --z-toast: 1000;

            /* Motion */
            --dur-fast:   150ms;
            --dur-normal: 250ms;
            --dur-slow:   400ms;
            --ease-out:   cubic-bezier(0.16, 1, 0.30, 1);
            --ease-in:    cubic-bezier(0.70, 0, 0.84, 0);
            --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        /* ============================================================
           REDUCED MOTION — Respect user preference
           ============================================================ */
        @@media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration:       0.01ms !important;
                animation-iteration-count: 1     !important;
                transition-duration:      0.01ms !important;
            }
        }

        /* ============================================================
           BASE
           ============================================================ */
        *, *::before, *::after { box-sizing: border-box; }

        html { scroll-behavior: smooth; }

        body {
            font-family:      var(--font-body);
            font-size:        16px;
            line-height:      1.6;
            background-color: var(--color-background);
            color:            var(--color-foreground);
            margin:           0;
            -webkit-font-smoothing: antialiased;
        }

        /* Skip link for keyboard nav */
        .skip-link {
            position: absolute;
            top: -100%;
            left: var(--space-4);
            background: var(--color-primary);
            color: var(--color-on-primary);
            padding: var(--space-2) var(--space-4);
            border-radius: var(--radius-md);
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            z-index: var(--z-toast);
            transition: top var(--dur-fast);
        }
        .skip-link:focus { top: var(--space-2); }

        /* ============================================================
           ANNOUNCEMENT BAR
           ============================================================ */
        .announcement-bar {
            background: var(--color-primary);
            color:       var(--color-accent-light);
            text-align:  center;
            font-family: var(--font-body);
            font-size:   12px;
            font-weight: 500;
            letter-spacing: 1.5px;
            padding: var(--space-2) var(--space-4);
            line-height: 1.4;
            transition: transform var(--dur-normal) var(--ease-in),
                        opacity  var(--dur-normal) var(--ease-in);
            overflow: hidden;
        }
        .announcement-bar.hidden {
            transform: translateY(-100%);
            opacity: 0;
            height: 0;
            padding: 0;
        }
        .announcement-bar span { display: inline; }

        /* ============================================================
           NAVBAR — Unified Sticky
           ============================================================ */
        .site-navbar {
            position:      sticky;
            top:           0;
            z-index:       var(--z-sticky);
            background:    rgba(250, 250, 249, 0.88);
            backdrop-filter: blur(20px) saturate(160%);
            -webkit-backdrop-filter: blur(20px) saturate(160%);
            border-bottom: 1px solid var(--color-border-subtle);
            transition:    box-shadow var(--dur-normal) var(--ease-out);
        }
        .site-navbar.scrolled {
            box-shadow: var(--shadow-md);
        }

        /* Logo */
        .site-navbar .navbar-brand {
            font-family:    var(--font-heading);
            font-size:      28px;
            font-weight:    700;
            color:          var(--color-accent-light) !important;
            letter-spacing: 1px;
            line-height:    1;
            text-decoration: none;
            flex-shrink:    0;
        }
        .site-navbar .brand-logo-img {
            height: 42px;
            width:  auto;
            object-fit: contain;
        }

        /* Nav links */
        .site-navbar .nav-link {
            font-family:    var(--font-body);
            font-size:      13px;
            font-weight:    500;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            color:          var(--color-secondary) !important;
            padding:        var(--space-2) var(--space-3) !important;
            border-radius:  var(--radius-sm);
            transition:     color var(--dur-fast) var(--ease-out),
                            background var(--dur-fast) var(--ease-out);
            position: relative;
        }
        .site-navbar .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0; left: 50%; right: 50%;
            height: 1.5px;
            background: var(--color-accent-light);
            transition: left var(--dur-normal) var(--ease-out),
                        right var(--dur-normal) var(--ease-out);
        }
        .site-navbar .nav-link:hover,
        .site-navbar .nav-link[aria-current="page"] {
            color: var(--color-accent) !important;
        }
        .site-navbar .nav-link:hover::after,
        .site-navbar .nav-link[aria-current="page"]::after {
            left: var(--space-3);
            right: var(--space-3);
        }

        /* Utility items (search, user, cart) */
        .navbar-utils {
            display:     flex;
            align-items: center;
            gap:         var(--space-1);
            flex-shrink: 0;
        }
        .navbar-util-btn {
            display:         flex;
            align-items:     center;
            justify-content: center;
            width:  44px;
            height: 44px;
            border-radius: var(--radius-full);
            background:    transparent;
            border:        none;
            color:         var(--color-secondary);
            cursor:        pointer;
            transition:    color       var(--dur-fast) var(--ease-out),
                           background  var(--dur-fast) var(--ease-out),
                           transform   var(--dur-fast) var(--ease-out);
            text-decoration: none;
            position: relative;
        }
        .navbar-util-btn:hover {
            color:      var(--color-accent);
            background: rgba(161, 98, 7, 0.06);
            transform:  translateY(-1px);
        }
        .navbar-util-btn:focus-visible {
            outline: 2px solid var(--color-accent-light);
            outline-offset: 2px;
        }
        .navbar-util-btn svg { width: 20px; height: 20px; flex-shrink: 0; }

        /* Cart badge */
        .cart-badge {
            position: absolute;
            top: 6px; right: 6px;
            background: var(--color-accent);
            color: white;
            font-size: 9px;
            font-weight: 700;
            width: 16px; height: 16px;
            border-radius: var(--radius-full);
            display: flex; align-items: center; justify-content: center;
            line-height: 1;
        }

        /* Account dropdown */
        .account-dropdown .dropdown-menu {
            border: 1px solid var(--color-border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg);
            padding: var(--space-2);
            min-width: 200px;
            animation: fadeDown var(--dur-normal) var(--ease-out);
        }
        .account-dropdown .dropdown-item {
            border-radius: var(--radius-md);
            font-size: 14px;
            padding: var(--space-2) var(--space-3);
            color: var(--color-foreground);
            transition: background var(--dur-fast) var(--ease-out),
                        color      var(--dur-fast) var(--ease-out);
            display: flex;
            align-items: center;
            gap: var(--space-2);
        }
        .account-dropdown .dropdown-item:hover {
            background: rgba(212, 175, 55, 0.08);
            color: var(--color-accent);
        }
        .account-dropdown .dropdown-item.text-danger { color: var(--color-destructive) !important; }
        .account-dropdown .dropdown-item.text-danger:hover { background: rgba(220, 38, 38, 0.06); }
        .account-dropdown .dropdown-divider { border-color: var(--color-border-subtle); margin: var(--space-1) 0; }

        /* Navbar toggler */
        .site-navbar .navbar-toggler {
            border:  1px solid var(--color-border);
            padding: var(--space-1) var(--space-2);
            border-radius: var(--radius-md);
            width:  44px; height: 44px;
        }
        .site-navbar .navbar-toggler:focus { box-shadow: 0 0 0 2px var(--color-accent-light); }

        /* Mobile collapse */
        @@media (max-width: 991.98px) {
            .site-navbar .navbar-collapse {
                background:    rgba(250, 250, 249, 0.97);
                border-radius: var(--radius-lg);
                margin-top:    var(--space-3);
                padding:       var(--space-3);
                box-shadow:    var(--shadow-lg);
                border:        1px solid var(--color-border-subtle);
            }
            .site-navbar .navbar-nav { gap: var(--space-1); }
            .site-navbar .nav-link::after { display: none; }
        }

        /* Dropdown sản phẩm */
        .site-navbar .dropdown-menu {
            border:        1px solid var(--color-border);
            border-radius: var(--radius-lg);
            box-shadow:    var(--shadow-lg);
            padding:       var(--space-3);
            min-width:     220px;
            animation:     fadeDown var(--dur-normal) var(--ease-out);
        }
        .site-navbar .dropdown-item {
            border-radius: var(--radius-md);
            font-size:     14px;
            padding:       var(--space-2) var(--space-3);
            color:         var(--color-foreground);
            transition:    background var(--dur-fast) var(--ease-out),
                           color      var(--dur-fast) var(--ease-out),
                           transform  var(--dur-fast) var(--ease-out);
        }
        .site-navbar .dropdown-item:hover {
            background: rgba(212, 175, 55, 0.08);
            color:      var(--color-accent);
            transform:  translateX(4px);
        }
        .site-navbar .dropdown-divider { border-color: var(--color-border-subtle); }

        @@ keyframes fadeDown {
            from { opacity: 0; transform: translateY(-8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* Utility top bar (desktop only) */
        .top-utility-bar {
            background: var(--color-background);
            border-bottom: 1px solid var(--color-border-subtle);
        }
        @@media (max-width: 991.98px) {
            .top-utility-bar { display: none; }
        }

        /* ============================================================
           HERO SLIDESHOW — Luxury redesign (v2)
           ============================================================ */
        .hero-section {
            position:    relative;
            aspect-ratio: 16 / 6.5;
            min-height:  260px;
            max-height:  640px;
            overflow:    hidden;
            background:  var(--color-primary);
            /* contain: layout isolates reflow inside the hero */
            contain:     layout;
        }

        /* All slides stacked — only opacity transitions (no transform transition) */
        .hero-slide {
            position:      absolute;
            inset:         0;
            width:         100%;
            height:        100%;
            object-fit:    cover;
            object-position: var(--slide-focus, 50% 50%);
            opacity:       0;
            pointer-events: none;
            /* GPU composite layer — only opacity, never transform transition */
            will-change:   opacity;
            transition:    opacity 850ms cubic-bezier(0.4, 0, 0.2, 1);
        }
        .hero-slide.active {
            opacity:       1;
            pointer-events: auto;
            /* Ken Burns via animation — removed when .active removed → no exit glitch */
            animation:     heroKenBurns 7s ease-out both;
        }
        @@keyframes heroKenBurns {
            from { transform: scale(1.05); }
            to   { transform: scale(1.00); }
        }
        .hero-slide.clickable { cursor: pointer; }

        /* Richer gradient overlay */
        .hero-overlay {
            position: absolute;
            inset:    0;
            background: linear-gradient(
                to bottom,
                transparent 30%,
                rgba(14, 10, 7, 0.72) 100%
            );
            pointer-events: none;
            z-index: 1;
        }

        /* ── Prev / Next arrows ── */
        .hero-arrow {
            position:  absolute;
            top:       50%;
            transform: translateY(-50%);
            z-index:   2;
            width:     48px; height: 48px;
            border-radius: var(--radius-full);
            background:    rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(14px) saturate(160%);
            -webkit-backdrop-filter: blur(14px) saturate(160%);
            border:    1.5px solid rgba(255, 255, 255, 0.22);
            color:     white;
            cursor:    pointer;
            display:   flex; align-items: center; justify-content: center;
            transition: background  200ms ease,
                        border-color 200ms ease,
                        transform   200ms ease;
            touch-action: manipulation;
        }
        .hero-arrow:hover {
            background:   rgba(212, 175, 55, 0.35);
            border-color: rgba(212, 175, 55, 0.60);
            transform:    translateY(-50%) scale(1.08);
        }
        .hero-arrow:focus-visible {
            outline:        2px solid var(--color-accent-light);
            outline-offset: 3px;
        }
        .hero-arrow--prev { left:  var(--space-6); }
        .hero-arrow--next { right: var(--space-6); }
        .hero-arrow svg   { width: 22px; height: 22px; }

        /* ── Dot controls — pip design (fixes oversized dot bug) ──
           Old: button with padding:17px + margin:-17px → huge layout area
           New: transparent 44x44 button + small visual pip inside           */
        .hero-controls {
            position:    absolute;
            bottom:      var(--space-5);
            left:        50%;
            transform:   translateX(-50%);
            display:     flex;
            align-items: center;
            z-index:     2;
            /* No gap — each .hero-dot-btn is 44×44 providing its own spacing */
        }
        /* Transparent touch-target button */
        .hero-dot-btn {
            width:   44px; height: 44px;
            background:  transparent;
            border:      none;
            cursor:      pointer;
            display:     flex;
            align-items: center; justify-content: center;
            padding:     0;
            touch-action: manipulation;
        }
        .hero-dot-btn:focus-visible {
            outline:        2px solid var(--color-accent-light);
            outline-offset: 2px;
            border-radius:  var(--radius-sm);
        }
        /* The visual pill — precise size, no layout effects */
        .hero-dot-pip {
            display:      block;
            height:       6px;
            width:        6px;
            border-radius: var(--radius-full);
            background:   rgba(255, 255, 255, 0.45);
            flex-shrink:  0;
            transition:   background 350ms ease,
                          width     350ms cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .hero-dot-btn.active .hero-dot-pip {
            background: var(--color-accent-light);
            width:      22px;
        }

        @@media (max-width: 767.98px) {
            .hero-section  { aspect-ratio: 4 / 3; }
            .hero-arrow    { display: none; }
            .hero-controls { bottom: var(--space-3); }
        }
        @@media (max-width: 480px) {
            .hero-section { aspect-ratio: 1 / 1; min-height: 0; }
        }
        /* Respect user motion preference */
        @@media (prefers-reduced-motion: reduce) {
            .hero-slide        { transition-duration: 50ms; }
            .hero-slide.active { animation: none; }
        }

        /* ============================================================
           CATEGORY BAR
           ============================================================ */
        .category-section {
            padding: var(--space-5) 0 var(--space-4);
            position: sticky;
            top: 58px; /* below navbar */
            z-index: var(--z-overlay);
            background: rgba(250, 250, 249, 0.92);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--color-border-subtle);
        }
        .category-bar {
            display:  flex;
            gap:      var(--space-2);
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            padding-bottom: var(--space-1);
        }
        .category-bar::-webkit-scrollbar { display: none; }

        .cat-pill {
            display:       inline-flex;
            align-items:   center;
            gap:           var(--space-1);
            padding:       var(--space-2) var(--space-5);
            min-height:    40px;
            border-radius: var(--radius-full);
            font-family:   var(--font-body);
            font-size:     13px;
            font-weight:   500;
            letter-spacing: 0.5px;
            white-space:   nowrap;
            flex-shrink:   0;
            text-decoration: none;
            cursor:        pointer;
            transition:    background var(--dur-fast) var(--ease-out),
                           color      var(--dur-fast) var(--ease-out),
                           box-shadow var(--dur-fast) var(--ease-out),
                           transform  var(--dur-fast) var(--ease-out);
            border:        1.5px solid var(--color-border);
            color:         var(--color-secondary);
            background:    var(--color-surface);
        }
        .cat-pill:hover {
            border-color: var(--color-accent-light);
            color:        var(--color-accent);
            transform:    translateY(-1px);
            box-shadow:   var(--shadow-sm);
        }
        .cat-pill.active,
        .cat-pill[aria-current="page"] {
            background:   var(--color-accent-light);
            border-color: var(--color-accent-light);
            color:        var(--color-primary);
            font-weight:  600;
            box-shadow:   var(--shadow-gold);
        }
        .cat-pill:focus-visible {
            outline: 2px solid var(--color-accent-light);
            outline-offset: 2px;
        }

        /* ============================================================
           MAIN CONTENT
           ============================================================ */
        .page-content {
            padding: var(--space-8) 0 var(--space-12);
            min-height: 40vh;
        }

        /* ============================================================
           VALUE / WHY CHOOSE SECTION
           ============================================================ */
        .value-section {
            background:   var(--color-primary);
            color:        var(--color-on-primary);
            padding:      var(--space-20) 0;
            position:     relative;
            overflow:     hidden;
        }
        /* Subtle gold texture overlay */
        .value-section::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(
                ellipse 80% 60% at 50% 0%,
                rgba(212, 175, 55, 0.07) 0%,
                transparent 70%
            );
            pointer-events: none;
        }

        .value-section .section-eyebrow {
            font-family:    var(--font-body);
            font-size:      11px;
            font-weight:    600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color:          var(--color-accent-light);
            margin-bottom:  var(--space-3);
            display:        block;
        }
        .value-section .section-title {
            font-family:  var(--font-heading);
            font-size:    clamp(28px, 4vw, 44px);
            font-weight:  700;
            color:        var(--color-on-primary);
            margin-bottom: var(--space-12);
            line-height:  1.15;
        }
        .value-section .section-title span {
            color: var(--color-accent-light);
            font-style: italic;
        }

        .value-card {
            display:  grid;
            grid-template-columns: 56px 1fr;
            gap:      var(--space-4);
            padding:  var(--space-6);
            border-radius: var(--radius-lg);
            border:   1px solid rgba(212, 175, 55, 0.12);
            background: rgba(255, 255, 255, 0.03);
            transition: transform    var(--dur-normal) var(--ease-out),
                        background   var(--dur-normal) var(--ease-out),
                        border-color var(--dur-normal) var(--ease-out),
                        box-shadow   var(--dur-normal) var(--ease-out);
        }
        .value-card:hover {
            transform:    translateY(-4px);
            background:   rgba(255, 255, 255, 0.06);
            border-color: rgba(212, 175, 55, 0.30);
            box-shadow:   var(--shadow-gold);
        }
        .value-icon-wrap {
            width:  56px; height: 56px;
            border-radius: var(--radius-lg);
            background: rgba(212, 175, 55, 0.10);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            border: 1px solid rgba(212, 175, 55, 0.20);
        }
        .value-icon-wrap svg {
            width: 26px; height: 26px;
            color: var(--color-accent-light);
        }
        .value-card-body { align-self: center; }
        .value-card h6 {
            font-family:    var(--font-body);
            font-size:      13px;
            font-weight:    600;
            letter-spacing: 1px;
            text-transform: uppercase;
            color:          var(--color-on-primary);
            margin-bottom:  var(--space-1);
        }
        .value-card p {
            font-size:   14px;
            line-height: 1.6;
            color:       rgba(255, 255, 255, 0.62);
            margin:      0;
        }

        /* ============================================================
           FOOTER
           ============================================================ */
        .site-footer {
            background: #F5F1EB;
            color:      var(--color-foreground);
            border-top: 1px solid var(--color-border);
            padding:    var(--space-16) 0 0;
            font-size:  14px;
        }

        .footer-brand {
            font-family: var(--font-heading);
            font-size:   32px;
            font-weight: 700;
            color:       var(--color-accent-light);
            margin-bottom: var(--space-3);
            display:     block;
        }
        .footer-tagline {
            font-size:   13px;
            color:       var(--color-text-secondary);
            line-height: 1.7;
            max-width:   260px;
            margin-bottom: var(--space-5);
        }
        .footer-social {
            display: flex;
            gap:     var(--space-3);
        }
        .footer-social-btn {
            display:         flex;
            align-items:     center;
            justify-content: center;
            width:  40px; height: 40px;
            border-radius: var(--radius-full);
            background:    transparent;
            border:        1.5px solid var(--color-border);
            color:         var(--color-secondary);
            text-decoration: none;
            transition:    color       var(--dur-fast) var(--ease-out),
                           background  var(--dur-fast) var(--ease-out),
                           border-color var(--dur-fast) var(--ease-out),
                           transform   var(--dur-fast) var(--ease-out);
        }
        .footer-social-btn:hover {
            background:   var(--color-accent-light);
            border-color: var(--color-accent-light);
            color:        var(--color-primary);
            transform:    translateY(-2px);
        }
        .footer-social-btn svg { width: 16px; height: 16px; }

        .footer-col-title {
            font-family:    var(--font-body);
            font-size:      11px;
            font-weight:    600;
            letter-spacing: 2px;
            text-transform: uppercase;
            color:          var(--color-accent);
            margin-bottom:  var(--space-4);
            display:        block;
        }

        .footer-links { list-style: none; padding: 0; margin: 0; }
        .footer-links li { margin-bottom: var(--space-2); }
        .footer-links a {
            color:           var(--color-secondary);
            text-decoration: none;
            font-size:       14px;
            transition:      color     var(--dur-fast) var(--ease-out),
                             transform var(--dur-fast) var(--ease-out);
            display:         inline-block;
        }
        .footer-links a:hover {
            color:     var(--color-accent);
            transform: translateX(4px);
        }

        .footer-contact-item {
            display:    flex;
            align-items: flex-start;
            gap:         var(--space-3);
            margin-bottom: var(--space-4);
        }
        .footer-contact-icon {
            width:  38px; height: 38px;
            border-radius: var(--radius-full);
            background:    var(--color-primary);
            color:         var(--color-accent-light);
            display:       flex;
            align-items:   center; justify-content: center;
            flex-shrink:   0;
        }
        .footer-contact-icon svg { width: 16px; height: 16px; }
        .footer-contact-label {
            font-size:   11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color:       var(--color-text-secondary);
            margin-bottom: 2px;
        }
        .footer-contact-value {
            font-family: var(--font-heading);
            font-size:   20px;
            font-weight: 600;
            color:       var(--color-foreground);
        }
        .footer-contact-value a {
            color: inherit; text-decoration: none;
            transition: color var(--dur-fast);
        }
        .footer-contact-value a:hover { color: var(--color-accent); }
        .footer-contact-sub {
            font-size: 12px;
            color:     var(--color-text-secondary);
        }

        .footer-showroom-img {
            width:  100%;
            border-radius: var(--radius-lg);
            object-fit:    cover;
            aspect-ratio:  3 / 2;
            transition:    transform var(--dur-slow) var(--ease-out);
        }
        .footer-showroom-link:hover .footer-showroom-img { transform: scale(1.03); }
        .footer-showroom-link { overflow: hidden; border-radius: var(--radius-lg); display: block; }

        /* Copyright strip */
        .footer-bottom {
            background:    var(--color-primary);
            color:         rgba(255, 255, 255, 0.55);
            text-align:    center;
            font-size:     12px;
            padding:       var(--space-4) var(--space-4);
            margin-top:    var(--space-12);
        }
        .footer-bottom strong { color: var(--color-accent-light); }
        .footer-bottom .footer-legal {
            max-width: 800px; margin: 0 auto;
            line-height: 1.7;
        }

        @@media (max-width: 767.98px) {
            .site-footer { padding-top: var(--space-12); }
            .footer-tagline { max-width: 100%; }
        }

        /* ============================================================
           CHAT WIDGET
           ============================================================ */
        .chat-widget { position: relative; }

        #chatIcon {
            position:      fixed;
            bottom:        var(--space-5);
            right:         var(--space-5);
            background:    linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
            color:         white;
            border:        none;
            border-radius: var(--radius-full);
            padding:       0 var(--space-5);
            height:        52px;
            min-width:     52px;
            display:       flex;
            align-items:   center;
            justify-content: center;
            gap:           var(--space-2);
            cursor:        pointer;
            box-shadow:    var(--shadow-gold);
            z-index:       var(--z-modal);
            font-family:   var(--font-body);
            font-size:     13px;
            font-weight:   600;
            letter-spacing: 0.3px;
            transition:    transform    var(--dur-normal) var(--ease-spring),
                           box-shadow   var(--dur-normal) var(--ease-out),
                           border-radius var(--dur-normal) var(--ease-out);
        }
        #chatIcon:hover {
            transform:  scale(1.04) translateY(-2px);
            box-shadow: 0 8px 28px rgba(161, 98, 7, 0.40);
        }
        #chatIcon:focus-visible {
            outline: 2px solid var(--color-accent-light);
            outline-offset: 3px;
        }
        #chatIcon svg { width: 20px; height: 20px; flex-shrink: 0; }

        #chatBox {
            display:       none;
            position:      fixed;
            bottom:        84px;
            right:         var(--space-5);
            width:         360px;
            max-width:     calc(100vw - 40px);
            background:    white;
            border-radius: var(--radius-xl);
            overflow:      hidden;
            box-shadow:    var(--shadow-xl);
            z-index:       var(--z-modal);
            border:        1px solid var(--color-border);
            animation:     chatSlideUp var(--dur-normal) var(--ease-out);
        }

        @@keyframes chatSlideUp {
            from { opacity: 0; transform: translateY(16px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0)    scale(1); }
        }

        .chat-header {
            background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
            padding:    var(--space-4);
            display:    flex;
            align-items: center;
            gap:         var(--space-3);
        }
        .chat-avatar {
            width:  44px; height: 44px;
            border-radius: var(--radius-full);
            background: white;
            overflow: hidden;
            flex-shrink: 0;
            border: 2px solid rgba(212, 175, 55, 0.4);
        }
        .chat-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .chat-header-info { flex: 1; }
        .chat-header-name {
            font-size:   15px;
            font-weight: 700;
            color:       white;
            font-family: var(--font-heading);
        }
        .chat-header-sub {
            font-size: 12px;
            opacity:   0.75;
            color:     rgba(212, 175, 55, 0.9);
        }
        .chat-close-btn {
            width:  36px; height: 36px;
            border-radius: var(--radius-full);
            border:  none;
            background: rgba(255,255,255,0.12);
            color:   white;
            cursor:  pointer;
            display: flex; align-items: center; justify-content: center;
            transition: background var(--dur-fast) var(--ease-out);
            flex-shrink: 0;
        }
        .chat-close-btn:hover { background: rgba(255,255,255,0.22); }
        .chat-close-btn:focus-visible { outline: 2px solid rgba(255,255,255,0.7); }
        .chat-close-btn svg { width: 16px; height: 16px; }

        #messagesList {
            height: 300px;
            overflow-y: auto;
            padding:    var(--space-4);
            background: #FAFAFA;
            display:    flex;
            flex-direction: column;
            gap: var(--space-3);
        }
        #messagesList::-webkit-scrollbar { width: 4px; }
        #messagesList::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 4px; }

        .chat-input-area {
            padding:      var(--space-3);
            border-top:   1px solid var(--color-border-subtle);
            background:   white;
        }
        .chat-input-row {
            display:     flex;
            align-items: center;
            gap:         var(--space-2);
        }
        #messageInput {
            flex:          1;
            border-radius: var(--radius-full);
            padding:       var(--space-2) var(--space-4);
            border:        1.5px solid var(--color-border);
            outline:       none;
            font-family:   var(--font-body);
            font-size:     14px;
            height:        44px;
            transition:    border-color var(--dur-fast) var(--ease-out);
        }
        #messageInput:focus { border-color: var(--color-accent-light); }
        #sendButton {
            width:         44px; height: 44px;
            border-radius: var(--radius-full);
            border:        none;
            background:    var(--color-accent-light);
            color:         var(--color-primary);
            cursor:        pointer;
            display:       flex;
            align-items:   center; justify-content: center;
            flex-shrink:   0;
            transition:    background var(--dur-fast) var(--ease-out),
                           transform  var(--dur-fast) var(--ease-spring);
        }
        #sendButton:hover { background: var(--color-accent-hover); transform: scale(1.05); }
        #sendButton:focus-visible { outline: 2px solid var(--color-accent-light); outline-offset: 2px; }
        #sendButton svg { width: 18px; height: 18px; }

        .chat-footer-note {
            text-align: center;
            font-size:  11px;
            color:      var(--color-text-secondary);
            padding:    var(--space-2) 0 var(--space-1);
        }

        @@media (max-width: 767.98px) {
            #chatIcon .chat-label { display: none; }
            #chatIcon { width: 52px; border-radius: var(--radius-full); padding: 0; }
        }

        /* ============================================================
           UTILS
           ============================================================ */
        a:focus-visible, button:focus-visible {
            outline: 2px solid var(--color-accent-light);
            outline-offset: 2px;
        }

    </style>
</head>
<body>
    <!-- Skip navigation — Accessibility -->
    <a href="#main-content" class="skip-link">Bỏ qua điều hướng</a>

    <!-- ANNOUNCEMENT BAR -->
    <div class="announcement-bar" id="announcementBar" role="banner" aria-label="Thông báo khuyến mãi">
        <span>✦ Miễn phí giao hàng đơn từ 500K &nbsp;·&nbsp; Đổi trả linh hoạt trong 7 ngày &nbsp;·&nbsp; Hỗ trợ 24/7: 1900 888 999 ✦</span>
    </div>

    <!-- TOP UTILITY BAR (desktop) -->
    <div class="top-utility-bar">
        @await Html.PartialAsync("_NavbarLogo")
    </div>

    <!-- MAIN NAVBAR -->
    <header class="site-navbar" id="siteNavbar" role="banner">
        <nav class="navbar navbar-expand-lg" aria-label="Điều hướng chính">
            <div class="container-fluid px-4">
                <!-- Logo -->
                <a class="navbar-brand d-flex align-items-center gap-2" href="/" aria-label="Flower Jewelry — Trang chủ">
                    <img src="https://i.pinimg.com/736x/73/fb/de/73fbde1145fa156318b20b494536e34f.jpg"
                         alt="" aria-hidden="true"
                         class="brand-logo-img"
                         width="42" height="42" />
                    <span>FLOWER JEWELRY</span>
                </a>

                <!-- Mobile toggle -->
                <button class="navbar-toggler ms-auto me-2" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false"
                        aria-label="Mở / đóng menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Nav links (center) -->
                <div class="collapse navbar-collapse justify-content-center" id="mainNav">
                    <ul class="navbar-nav gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Index"
                               aria-current="@(Context.Request.Path == "/" ? "page" : null)">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="GioiThieu" asp-action="Index">Giới thiệu</a>
                        </li>

                        <!-- Sản phẩm dropdown -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#"
                               id="productDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                Sản phẩm
                            </a>
                            <ul class="dropdown-menu shadow-lg border-0"
                                aria-labelledby="productDropdown">
                                <li>
                                    <a class="dropdown-item fw-semibold" href="/Products">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="margin-right:6px;opacity:0.7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                                        Tất cả sản phẩm
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                @await Component.InvokeAsync("CategoryDropdown")
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TinTuc" asp-action="Index">Tin tức</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/customer/my-orders">Đơn hàng</a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" href="/LienHe/Index">Liên hệ</a>
                        </li>
                    </ul>
                </div>

                <!-- Utils: account + cart -->
                <div class="navbar-utils">
                    <!-- Account -->
                    <div class="account-dropdown dropdown">
                        <button class="navbar-util-btn dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false"
                                aria-label="Tài khoản">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                            </svg>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <li>
                                    <a class="dropdown-item" href="/CustomerAccount/MyAccount">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                        Tài khoản của tôi
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/customer/my-orders">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M5 12a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2"/><path d="M5 12a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2"/></svg>
                                        Đơn hàng của tôi
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form method="post" asp-controller="CustomerAccount" asp-action="Logout" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                                            Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <a class="dropdown-item" href="/CustomerAccount/Login">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                                        Đăng nhập
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/CustomerAccount/Register">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                                        Đăng ký
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                    <!-- Cart -->
                    <a href="/Cart" class="navbar-util-btn" aria-label="Giỏ hàng">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                        </svg>
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <!-- HERO SLIDESHOW (trang chủ only) -->
    @if (Context.Request.Path == "/" || Context.Request.Path.ToString().ToLower() == "/home/index")
    {
        var homeBanners = StoreRepository.Banners
            .Where(b => b.IsActive)
            .OrderBy(b => b.DisplayOrder)
            .ThenBy(b => b.BannerID)
            .ToList();

        if (homeBanners.Any())
        {
            <section class="hero-section" id="heroSlideshow" aria-label="Banner hình ảnh" role="region">
                @for (var i = 0; i < homeBanners.Count; i++)
                {
                    var banner      = homeBanners[i];
                    var redirectUrl = banner.RedirectUrl?.Trim();
                    if (!string.IsNullOrWhiteSpace(redirectUrl)
                        && !redirectUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
                        && !redirectUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
                        && !redirectUrl.StartsWith("/"))
                    {
                        redirectUrl = $"https://{redirectUrl}";
                    }

                    var isClickable  = !string.IsNullOrWhiteSpace(redirectUrl);
                    var slideClass   = i == 0 ? "hero-slide active" : "hero-slide";
                    if (isClickable) slideClass += " clickable";
                    /* CSS custom prop for object-position — avoids direct inline style */
                    var slideStyle   = $"--slide-focus:{banner.FocusX}% {banner.FocusY}%";
                    var loading      = i == 0 ? "eager"  : "lazy";
                    var fetchPri     = i == 0 ? "high"   : "auto";
                    var decoding     = i == 0 ? "sync"   : "async";

                    if (isClickable)
                    {
                        <a href="@redirectUrl" tabindex="-1" aria-label="@banner.Title" aria-hidden="true">
                            <img src="@banner.ImageUrl"
                                 class="@slideClass"
                                 style="@slideStyle"
                                 alt="@banner.Title"
                                 width="1920" height="768"
                                 loading="@loading"
                                 fetchpriority="@fetchPri"
                                 decoding="@decoding" />
                        </a>
                    }
                    else
                    {
                        <img src="@banner.ImageUrl"
                             class="@slideClass"
                             style="@slideStyle"
                             alt="@banner.Title"
                             width="1920" height="768"
                             loading="@loading"
                             fetchpriority="@fetchPri"
                             decoding="@decoding" />
                    }
                }

                <!-- Gradient overlay -->
                <div class="hero-overlay" aria-hidden="true"></div>

                <!-- Prev / Next arrows -->
                @if (homeBanners.Count > 1)
                {
                    <button class="hero-arrow hero-arrow--prev" id="heroPrev" aria-label="Ảnh trước">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button class="hero-arrow hero-arrow--next" id="heroNext" aria-label="Ảnh tiếp theo">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                }

                <!-- Dot controls — pip style (fix oversized dots) -->
                <div class="hero-controls" role="group" aria-label="Chuyển slide">
                    @for (var i = 0; i < homeBanners.Count; i++)
                    {
                        <button class="hero-dot-btn @(i == 0 ? "active" : "")"
                                data-index="@i"
                                aria-label="Ảnh @(i+1) / @homeBanners.Count"
                                aria-pressed="@(i == 0 ? "true" : "false")">
                            <span class="hero-dot-pip" aria-hidden="true"></span>
                        </button>
                    }
                </div>
            </section>
        }
    }

    <!-- MAIN CONTENT -->
    <main id="main-content">
        @{
            var currentPath = Context.Request.Path.ToString().ToLower();
        }

        @if (currentPath == "/")
        {
            var currentCategory = Context.Request.Query["category"].ToString();

            <!-- Category filter bar (trang chủ only) -->
            <div class="category-section">
                <div class="container">
                    <nav class="category-bar" role="navigation" aria-label="Lọc theo danh mục">
                        <a href="/"
                           class="cat-pill @(string.IsNullOrWhiteSpace(currentCategory) ? "active" : "")"
                           aria-current="@(string.IsNullOrWhiteSpace(currentCategory) ? "page" : null)">
                            Tất cả
                        </a>
                        @await Component.InvokeAsync("CategoryMenu")
                    </nav>
                </div>

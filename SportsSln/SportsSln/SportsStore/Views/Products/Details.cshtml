@model SportsStore.Models.Product

@{
    ViewData["Title"] = Model.Name;
    var otherProducts = (ViewBag.OtherProducts as IEnumerable<SportsStore.Models.Product>)?.ToList() ?? new List<SportsStore.Models.Product>();
}

<div class="container py-5">
    <div class="row">
        <!-- Hình ảnh sản phẩm -->
        <div class="col-md-5 text-center">
            <img src="~/images/@Model.ImageUrl"
                 alt="@Model.Name"
                 class="img-fluid rounded shadow-sm border"
                 style="max-height: 400px; object-fit: contain;">
        </div>

        <!-- Thông tin chi tiết -->
        <div class="col-md-7">
            <h2 class="fw-bold text-dark mb-3">@Model.Name</h2>
            <p class="text-muted mb-4">@Model.Description</p>

            <h3 class="text-danger fw-bold mb-4">@Model.Price.ToString("N0") ₫</h3>

            @if (Model.Quantity == 0)
            {
                <!-- Nếu hết hàng thì chỉ hiện thông báo -->
                <div class="alert alert-danger fw-bold">
                    Sản phẩm này đã hết hàng
                </div>
            }
            else
            {
                <!-- Không còn size – chỉ còn nút mua -->
                <p class="text-muted mb-3">
                    <b>Phân loại:</b> @Model.Category?.Name
                </p>

                <!-- Nút thêm vào giỏ hàng -->
                <form id="addToCartForm" method="post">
                    <input type="hidden" name="productId" value="@Model.ProductID" />

                    <button type="submit" class="btn btn-outline-dark btn-lg">
                        <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ hàng
                    </button>
                </form>

                <!-- Nút mua ngay -->
                <form id="buyNowForm" method="post" asp-page="/Cart" asp-page-handler="BuyNow" class="mt-2">
                    <input type="hidden" name="productId" value="@Model.ProductID" />

                    <button type="submit" class="btn btn-gold btn-lg">
                        <i class="fa-solid fa-bolt"></i> Mua ngay
                    </button>
                </form>
            }

            <a asp-action="Index" class="btn btn-link text-decoration-none mt-3">
                <i class="fa-solid fa-arrow-left"></i> Quay lại sản phẩm
            </a>
        </div>
    </div>

    <!-- ===== SẢN PHẨM KHÁC ===== -->
    @if (otherProducts.Any())
    {
        <hr class="my-5" />
        <h4 class="mb-4">Sản phẩm khác bạn có thể quan tâm</h4>
        <div class="row row-cols-1 row-cols-md-4 g-4">
            @foreach (var p in otherProducts)
            {
                <div class="col">
                    <a asp-action="Details" asp-route-id="@p.ProductID" class="text-decoration-none text-dark">
                        <div class="card h-100 text-center shadow-sm border-0 product-card">
                            <img src="~/images/@p.ImageUrl"
                                 class="card-img-top p-3"
                                 alt="@p.Name"
                                 style="height:150px; object-fit:contain;" />
                            <div class="card-body">
                                <h6 class="card-title fw-semibold mb-1">@p.Name</h6>
                                <h6 class="text-danger fw-bold">@p.Price.ToString("N0") ₫</h6>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>

        // Add to Cart
        document.getElementById("addToCartForm").addEventListener("submit", function (e) {
            e.preventDefault();

            const formData = new FormData(this);

            fetch("/Cart?handler=Add", {
                method: "POST",
                body: formData
            })
                .then(res => res.json())
                .then(data => {
                    if (data.loginRequired) {
                        alert("Bạn phải đăng nhập trước khi thêm vào giỏ hàng!");
                        window.location.href = data.loginUrl || "/CustomerAccount/Login";
                        return;
                    }

                    if (data.success) {
                        alert("Đã thêm sản phẩm vào giỏ hàng!");
                    } else {
                        alert("Có lỗi khi thêm sản phẩm!");
                    }
                })
                .catch(() => alert("Không thể kết nối máy chủ!"));
        });

        // Buy Now (không cần size)
        document.getElementById("buyNowForm").addEventListener("submit", function (e) {
            // Không cần validation size nữa
        });
    </script>
}

<style>
    .btn-gold {
        background-color: #d4af37;
        color: #fff;
        font-weight: 600;
        border-radius: 8px;
        padding: 10px 24px;
        transition: all 0.3s ease;
    }

        .btn-gold:hover {
            background-color: #b9972f;
            transform: scale(1.05);
        }

    .product-card {
        transition: all 0.3s ease;
        border-radius: 10px;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

        .product-card img {
            transition: transform 0.3s ease;
        }

        .product-card:hover img {
            transform: scale(1.05);
        }
</style>

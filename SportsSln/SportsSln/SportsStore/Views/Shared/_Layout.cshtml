<!-- SIGNALR -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.0/signalr.min.js"></script>

<script>
    // Mở chat
        // Mở chat
    document.getElementById("chatIcon").onclick = function () {
        document.getElementById("chatBox").style.display = "block";
        this.style.display = "none";

        // Hiển thị tin nhắn mặc định từ admin
        renderMessage("Flower Jewelry", "Flower Jewelry xin chào\nFlower Jewelry có thể hỗ trợ gì cho mình hôm nay không ạ?");
    };


    // Đóng chat
    document.getElementById("closeChat").onclick = function () {
        document.getElementById("chatBox").style.display = "none";
        document.getElementById("chatIcon").style.display = "flex";
    };

    // SignalR
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chathub")
        .build();

    const currentUser = "Bạn";

    // Tạo bong bóng chat
    function renderMessage(user, message) {
        const container = document.getElementById("messagesList");
        const wrap = document.createElement("div");
        const bubble = document.createElement("div");

        bubble.style.maxWidth = "70%";
        bubble.style.padding = "10px 14px";
        bubble.style.borderRadius = "16px";
        bubble.style.fontSize = "14px";
        bubble.style.whiteSpace = "pre-wrap";

        // Bạn → bên phải
        if (user === currentUser) {
            wrap.style.display = "flex";
            wrap.style.justifyContent = "flex-end";
            bubble.style.background = "#f39a9a";
            bubble.style.color = "white";
        }
        // Admin → bên trái
        else {
            wrap.style.display = "flex";
            wrap.style.justifyContent = "flex-start";
            bubble.style.background = "#f0f0f0";
            bubble.style.color = "#000";
        }

        bubble.textContent = message;
        wrap.appendChild(bubble);
        container.appendChild(wrap);

        container.scrollTop = container.scrollHeight;
    }

    // Nhận tin nhắn
    connection.on("ReceiveMessage", (user, message) => {
        renderMessage(user, message);
    });

    // Start
    connection.start().catch(err => console.error(err.toString()));

    // Gửi tin nhắn
    document.getElementById("sendButton").onclick = function () {
        const message = document.getElementById("messageInput").value.trim();
        if (message === "") return;

        connection.invoke("SendMessage", currentUser, message);
        document.getElementById("messageInput").value = "";
    };
</script>

</div>




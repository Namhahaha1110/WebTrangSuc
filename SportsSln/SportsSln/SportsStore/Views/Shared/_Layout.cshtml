@* Pages/Shared/_Layout.cshtml *@
@inject SportsStore.Models.IStoreRepository StoreRepository
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Flower Jewelry</title>

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />
    <!-- FONT AWESOME -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" />
    <!-- GOOGLE FONT -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />

    <style>
        :root {
            --jewel-gold: #d4af37;
            --jewel-pink: #f8e1e7;
            --jewel-dark: #2a2a2a;
            --jewel-white: #ffffff;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--jewel-white);
            color: var(--jewel-dark);
            margin: 0;
        }

        /* ---------- HEADER ---------- */
        .site-navbar {
            background: var(--jewel-white);
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
            position: sticky;
            top: 0;
            z-index: 100;
        }

            .site-navbar .navbar-brand {
                font-family: 'Playfair Display', serif;
                font-size: 32px;
                color: var(--jewel-gold);
                letter-spacing: 1px;
            }

            .site-navbar .nav-link {
                color: #333 !important;
                font-weight: 500;
                text-transform: uppercase;
                transition: 0.3s;
            }

                .site-navbar .nav-link:hover {
                    color: var(--jewel-gold) !important;
                }

        /* ---------- CART ICON ---------- */
        .cart-icon {
            color: var(--jewel-gold);
            font-size: 22px;
            margin-left: 20px;
            transition: 0.3s;
        }

        .mobile-account {
            display: none;
        }

        .mobile-account .btn {
            border-color: rgba(212, 175, 55, 0.6);
            color: #6b4e16;
            font-weight: 500;
            background: #fff9eb;
        }

        .mobile-account .btn:focus {
            box-shadow: 0 0 0 0.2rem rgba(212, 175, 55, 0.22);
        }

        .mobile-account .dropdown-menu {
            width: max-content;
            max-width: calc(100vw - 16px);
            overflow-x: hidden;
        }

        .mobile-account .dropdown-item {
            white-space: nowrap;
        }

            .cart-icon:hover {
                color: #b9972f;
                transform: scale(1.1);
            }

        /* ---------- SLIDESHOW ---------- */
        .image-container {
            width: 100%;
            height: 420px;
            position: relative;
            overflow: hidden;
            background: #fff6fa;
        }

        .sliding-image {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0;
            transform: scale(1.02);
            pointer-events: none;
            transition: opacity 1s ease-in-out, transform 8s linear;
        }

            .sliding-image.active {
                opacity: 1;
                transform: scale(1);
                pointer-events: auto;
            }

        .sliding-image.clickable {
            cursor: pointer;
        }

        .controls {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 10px;
            z-index: 10;
        }

            .controls .button {
                width: 12px;
                height: 12px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.6);
                border: 1px solid rgba(0, 0, 0, 0.15);
                cursor: pointer;
            }

                .controls .button.active {
                    background: var(--jewel-gold);
                }

        /* ---------- MAIN CONTENT ---------- */
        .main-wrapper {
            display: flex;
            flex-wrap: wrap;
            padding: 30px 40px;
        }

        #categories {
            flex: 0 0 250px;
            background: var(--jewel-pink);
            border-radius: 10px;
            padding: 16px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
            height: fit-content;
        }

        .main-content {
            flex: 1;
            padding-left: 40px;
        }

        /* ---------- WHY CHOOSE ---------- */
        .why-choose {
            background: #fff8fb;
            border-top: 3px solid var(--jewel-gold);
            border-bottom: 3px solid var(--jewel-gold);
            padding: 50px 0;
        }

            .why-choose h3 {
                text-align: center;
                font-weight: 700;
                margin-bottom: 40px;
                color: var(--jewel-dark);
                font-family: 'Playfair Display', serif;
            }

        .why-card {
            background: #fff;
            border-radius: 12px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.05);
            transition: 0.3s;
        }

            .why-card:hover {
                transform: scale(1.05);
            }

            .why-card i {
                font-size: 30px;
                color: var(--jewel-gold);
                margin-bottom: 10px;
            }

        /* ---------- FOOTER ---------- */
        footer {
            background: var(--jewel-dark);
            color: #fff;
            text-align: center;
            padding: 14px 0;
        }

        @@media (max-width: 768px) {
            .main-wrapper {
                flex-direction: column;
                padding: 20px;
            }

            .main-content {
                padding-left: 0;
                margin-top: 20px;
            }

            #categories {
                width: 100%;
            }
        }



        footer {
            background-color: #f9f9f9 !important;
            color: #222 !important;
        }

            footer h6,
            footer .fw-bold {
                color: var(--jewel-gold) !important;
            }

            footer a {
                color: #333 !important;
                transition: color 0.3s;
            }

                footer a:hover {
                    color: var(--jewel-gold) !important;
                }


        /* ======= MEGA MENU SẢN PHẨM ======= */
        .navbar .dropdown-menu.mega-menu {
            display: none;
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            max-width: 1200px;
            margin-top: 10px;
            border: none;
            border-radius: 10px;
            background-color: #fff;
            padding: 30px 50px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
            z-index: 999;
        }

        .navbar .dropdown:hover .dropdown-menu.mega-menu,
        .navbar .dropdown.show .dropdown-menu.mega-menu {
            display: block;
        }

        .mega-menu .col-md-3 {
            padding: 10px 25px;
        }

        .mega-menu .dropdown-header {
            font-size: 17px;
            font-weight: 600;
            color: var(--jewel-gold);
            text-transform: uppercase;
            margin-bottom: 10px;
            border-bottom: 1px solid #eee;
            padding-bottom: 5px;
        }

        .mega-menu .dropdown-item {
            color: #222;
            font-size: 16px;
            line-height: 1.8;
            font-weight: 400;
            padding: 3px 0;
            white-space: nowrap;
            transition: all 0.3s ease;
        }

            .mega-menu .dropdown-item:hover {
                color: var(--jewel-gold);
                background: transparent;
                transform: translateX(5px);
            }
        /* Tùy chỉnh đẹp hơn cho dropdown sản phẩm */
        .dropdown-menu {
            animation: fadeDown 0.25s ease-in-out;
        }

        @@keyframes fadeDown {
            from

        {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .dropdown-item {
            padding: 8px 15px;
            border-radius: 6px;
            transition: all 0.2s ease;
        }

            .dropdown-item:hover {
                background-color: #f8e1e7;
                color: #d4af37 !important;
            }


 
        .category-bar a {
            border-radius: 25px;
            font-weight: 500;
            transition: all 0.3s;
            padding: 8px 18px;
        }

        .category-bar a:hover,
        .category-bar a.active {
            background-color: #d4af37;
            color: white !important;
            border-color: #d4af37;
        }

        .category-bar {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            padding-bottom: 4px;
        }

        .category-bar::-webkit-scrollbar {
            height: 6px;
        }

        .category-bar::-webkit-scrollbar-thumb {
            background: rgba(212, 175, 55, 0.45);
            border-radius: 999px;
        }

        .chat-widget {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 9999;
        }

        @@media (max-width: 991.98px) {
            .top-utility-bar {
                display: none;
            }

            .mobile-account {
                display: block;
            }

            .mobile-account .dropdown-menu {
                min-width: 210px;
                right: 0;
                left: auto;
            }

            .site-navbar .navbar-brand {
                font-size: 24px;
            }

            .site-navbar .navbar-collapse {
                background: #fff;
                margin-top: 10px;
                border-radius: 10px;
                padding: 10px 12px;
                box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
            }

            .site-navbar .navbar-nav {
                align-items: flex-start;
                gap: 4px;
            }

            .site-navbar .navbar-nav .dropdown-menu {
                width: 100%;
                min-width: 0 !important;
            }

            .site-navbar .cart-icon {
                margin-left: 0;
            }
        }

        @@media (max-width: 767.98px) {
            .image-container {
                height: 250px;
            }

            .controls {
                bottom: 12px;
            }

            .controls .button {
                width: 10px;
                height: 10px;
            }

            .category-bar {
                justify-content: flex-start !important;
                flex-wrap: nowrap !important;
                gap: 10px !important;
                padding-inline: 4px;
            }

            .category-bar a {
                white-space: nowrap;
                flex: 0 0 auto;
            }

            footer {
                font-size: 14px !important;
            }

            footer .text-end {
                text-align: left !important;
            }

            footer img[style*='float:right'] {
                float: none !important;
                display: block;
                margin-left: 0;
            }

            .chat-widget #chatIcon {
                width: 58px !important;
                height: 58px !important;
                border-radius: 50% !important;
                padding: 0 !important;
                gap: 0 !important;
            }

            .chat-widget #chatIcon span {
                display: none !important;
            }

            .chat-widget #chatBox {
                width: calc(100vw - 20px) !important;
                right: 10px !important;
                bottom: 86px !important;
            }

            .mobile-account .btn {
                padding: 0.32rem 0.55rem;
            }

            .mobile-account .btn span {
                display: none !important;
            }

            .site-navbar .navbar-brand {
                font-size: 22px;
            }
        }


    </style>
</head>
<body>
    <!-- HEADER -->
    <div class="top-utility-bar">
        @await Html.PartialAsync("_NavbarLogo")
    </div>

    <header class="site-navbar">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">FLOWER JEWELRY</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-center" id="mainNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Products" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="GioiThieu" asp-action="Index">Giới thiệu</a>
                        </li>

                        <!-- Dropdown SẢN PHẨM -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Sản phẩm
                            </a>

                            <ul class="dropdown-menu dropdown-menu-center p-3 shadow-lg border-0"
                                aria-labelledby="navbarDropdown"
                                style="min-width: 250px; border-radius: 12px; font-size: 15px;">
                                <li><a class="dropdown-item fw-bold text-center" href="/Products">Tất cả</a></li>
                                <li><hr class="dropdown-divider" /></li>

                                @await Component.InvokeAsync("CategoryDropdown")
                            </ul>

                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TinTuc" asp-action="Index">Tin tức</a>
                        </li>

                        <!-- Add My Orders link - only show when logged in -->
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/customer/my-orders">Đơn hàng của tôi</a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" href="/LienHe/Index">Liên hệ</a>
                        </li>
                    </ul>
                </div>


                <!-- Cart Icon -->
                <div class="d-flex align-items-center pe-3 gap-2">
                    <div class="dropdown mobile-account">
                        <button class="btn btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa-solid fa-user"></i>
                            <span class="ms-1 d-none d-sm-inline">Tài khoản</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <li><a class="dropdown-item" href="/CustomerAccount/MyAccount"><i class="fa-regular fa-user me-2"></i>Tài khoản của tôi</a></li>
                                <li><a class="dropdown-item" href="/customer/my-orders"><i class="fa-solid fa-box me-2"></i>Đơn hàng của tôi</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form method="post" asp-controller="CustomerAccount" asp-action="Logout" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                                <li><a class="dropdown-item" href="/CustomerAccount/Login"><i class="fa-solid fa-right-to-bracket me-2"></i>Đăng nhập</a></li>
                                <li><a class="dropdown-item" href="/CustomerAccount/Register"><i class="fa-solid fa-user-plus me-2"></i>Đăng ký</a></li>
                            }
                        </ul>
                    </div>
                    <a href="/Cart" class="cart-icon"><i class="fa-solid fa-shopping-cart"></i></a>
                </div>
            </div>
        </nav>
    </header>

    <!-- SLIDESHOW -->
    @if (Context.Request.Path == "/" || Context.Request.Path.ToString().ToLower() == "/home/index")
    {
        var homeBanners = StoreRepository.Banners
            .Where(b => b.IsActive)
            .OrderBy(b => b.DisplayOrder)
            .ThenBy(b => b.BannerID)
            .ToList();

        <div class="image-container" id="mainSlideshow">
            @for (var i = 0; i < homeBanners.Count; i++)
            {
                var banner = homeBanners[i];
                var redirectUrl = banner.RedirectUrl?.Trim();
                if (!string.IsNullOrWhiteSpace(redirectUrl)
                    && !redirectUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
                    && !redirectUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
                    && !redirectUrl.StartsWith("/"))
                {
                    redirectUrl = $"https://{redirectUrl}";
                }

                var isClickable = !string.IsNullOrWhiteSpace(redirectUrl);
                var imageClass = i == 0
                    ? (isClickable ? "sliding-image active clickable" : "sliding-image active")
                    : (isClickable ? "sliding-image clickable" : "sliding-image");
                var imagePosition = $"object-position:{banner.FocusX}% {banner.FocusY}%;";

                if (isClickable)
                {
                    <a href="@redirectUrl">
                        <img src="@banner.ImageUrl" class="@imageClass" style="@imagePosition" alt="@banner.Title" />
                    </a>
                }
                else
                {
                    <img src="@banner.ImageUrl" class="@imageClass" style="@imagePosition" alt="@banner.Title" />
                }
            }

            <div class="controls">
                @for (var i = 0; i < homeBanners.Count; i++)
                {
                    var buttonClass = i == 0 ? "button active" : "button";
                    <button class="@buttonClass" data-index="@i"></button>
                }
            </div>
        </div>
    }
   @{
    var currentPath = Context.Request.Path.ToString().ToLower();
}
    @if (currentPath == "/")
    {
        var currentCategory = Context.Request.Query["category"].ToString();
        <div class="container my-4">
            <!-- Thanh phân loại nằm ngang -->
            <div id="categories" class="category-bar d-flex flex-wrap justify-content-center gap-3 mb-4">
                <a href="/" class="btn btn-outline-dark @(string.IsNullOrWhiteSpace(currentCategory) ? "active" : "")">Tất cả</a>
                @await Component.InvokeAsync("CategoryMenu")
            </div>

            <div>
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        <div class="container mt-4">
            @RenderBody()
        </div>
    }
    <!-- WHY CHOOSE -->
    <section class="why-choose">
        <div class="container">
            <h3>TẠI SAO CHỌN <span style="color:var(--jewel-gold)">FLOWER JEWELRY?</span></h3>
            <div class="row g-4 justify-content-center">
                <div class="col-md-3 col-sm-6">
                    <div class="why-card">
                        <i class="fa-solid fa-gem"></i>
                        <h6>CHẤT LƯỢNG CAO CẤP</h6>
                        <p>Trang sức tinh xảo, được chế tác từ nguyên liệu chọn lọc.</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="why-card">
                        <i class="fa-solid fa-gift"></i>
                        <h6>MẪU MÃ ĐA DẠNG</h6>
                        <p>Phù hợp cho mọi dịp, quà tặng đến sự kiện đặc biệt.</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="why-card">
                        <i class="fa-solid fa-rotate"></i>
                        <h6>ĐỔI TRẢ LINH HOẠT</h6>
                        <p>Đổi trả trong 7 ngày nếu sản phẩm không như mong đợi.</p>
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="why-card">
                        <i class="fa-solid fa-headset"></i>
                        <h6>HỖ TRỢ 24/7</h6>
                        <p>Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FOOTER (chuẩn Huy Thanh Jewelry style) -->
    <footer style="background-color:#fff; color:#000; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif; font-size:15px; line-height:1.7; padding:50px 0 10px;">
        <div class="container">
            <div class="row">
                <!-- CỘT 1: HOTLINE -->
                <div class="col-md-4 col-sm-12 mb-4" style="text-align: left;">
                    <div class="d-flex align-items-start mb-4">
                        <div style="background-color:#000; color:#fff; border-radius:50%; width:45px; height:45px; display:flex; align-items:center; justify-content:center; margin-right:15px;">
                            <i class="fa-solid fa-phone"></i>
                        </div>
                        <div>
                            <p class="mb-1" style="font-weight:600; margin:0;">
                                GỌI MUA HÀNG (Phím 1)
                                <span style="font-weight:400;">(8:00 - 21:00)</span>
                            </p>
                            <p class="mb-1" style="font-size:22px; font-weight:500; margin:0;">
                                <a href="tel:1900888999" style="color:#000; text-decoration:none;">1900 888 999</a>
                            </p>
                            <small>Tất cả các ngày trong tuần</small>
                        </div>
                    </div>

                    <div class="d-flex align-items-start">
                        <div style="background-color:#000; color:#fff; border-radius:50%; width:45px; height:45px; display:flex; align-items:center; justify-content:center; margin-right:15px;">
                            <i class="fa-solid fa-phone"></i>
                        </div>
                        <div>
                            <p class="mb-1" style="font-weight:600; margin:0;">
                                GÓP Ý, KHIẾU NẠI (Phím 3)
                                <span style="font-weight:400;">(8:00 - 21:00)</span>
                            </p>
                            <p class="mb-1" style="font-size:22px; font-weight:500; margin:0;">
                                <a href="tel:1900246864" style="color:#000; text-decoration:none;">1900 246 864</a>
                            </p>
                            <small>Tất cả các ngày trong tuần</small>
                        </div>
                    </div>
                </div>

                <!-- CỘT 2: SHOWROOM -->
                <div class="col-md-4 col-sm-12 mb-4 text-center">
                    <a class="nav-link" asp-controller="CuaHang" asp-action="Index"
                       style="display:inline-block; text-decoration:none; color:inherit;">
                        <p style="font-weight:600; text-transform:uppercase; margin-bottom:10px; transition:color 0.3s;">
                            HỆ THỐNG SHOWROOM
                        </p>
                        <img src="https://huythanhjewelry.vn/storage/photos/shares/Footer/ft_showroom_image_custom.webp"
                             alt="Hệ thống cửa hàng"
                             class="img-fluid"
                             style="border-radius:4px; transition:transform 0.3s;">
                    </a>
                </div>

                <!-- CỘT 3: FANPAGE -->
                <div class="col-md-4 col-sm-12 mb-4 text-center">
                    <p style="font-weight:600; text-transform:uppercase; margin-bottom:10px;">FANPAGE CỦA CHÚNG TÔI</p>
                    <img src="https://huythanhjewelry.vn/storage/photos/shares/Footer/footer-fanpage-custom-image.webp"
                         alt="Fanpage Flower Jewelry"
                         class="img-fluid"
                         style="border-radius:4px; margin-bottom:15px;">
                    <div class="d-flex justify-content-center gap-4">
                        <a href="#" style="color:#000;"><i class="fab fa-facebook-f fa-lg"></i></a>
                        <a href="#" style="color:#000;"><i class="fab fa-instagram fa-lg"></i></a>
                        <a href="#" style="color:#000;"><i class="fab fa-youtube fa-lg"></i></a>
                        <a href="#" style="color:#000;"><i class="fab fa-tiktok fa-lg"></i></a>
                    </div>
                </div>
            </div>

            <!-- THÔNG TIN CÔNG TY -->
            <div class="text-end mt-4" style="color:#555; font-size:11px; text-align:right;">
                <p class="fw-bold mb-1" style="color:#2d2d2d;">CÔNG TY TNHH VÀNG BẠC ĐÁ QUÝ FLOWER JEWELRY</p>

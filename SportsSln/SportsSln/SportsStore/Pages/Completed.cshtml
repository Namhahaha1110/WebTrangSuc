@page 
@model SportsStore.Pages.CompletedModel
@{
    ViewData["Title"] = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: #f8f5f0;
        font-family: 'Segoe UI', 'Helvetica Neue', sans-serif;
    }

    .success-container {
        max-width: 700px;
        margin: 80px auto;
        text-align: center;
        padding: 50px;
        background: linear-gradient(145deg, #fffef9, #f7f2e9);
        border-radius: 20px;
        color: #444;
        box-shadow: 0 8px 32px rgba(180, 160, 120, 0.25);
        border: 1px solid rgba(230, 210, 160, 0.4);
        position: relative;
        overflow: hidden;
    }

        .success-container::before {
            content: "";
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at center, rgba(255, 215, 130, 0.15), transparent 70%);
            z-index: 0;
        }

    .success-icon {
        font-size: 90px;
        color: #d4af37;
        margin-bottom: 20px;
        animation: bounceIn 0.8s ease;
        z-index: 1;
        position: relative;
    }

    .success-title {
        font-size: 34px;
        font-weight: 700;
        color: #b8860b;
        margin-bottom: 15px;
        letter-spacing: 1px;
        z-index: 1;
        position: relative;
    }

    .success-message {
        font-size: 17px;
        margin-bottom: 30px;
        opacity: 0.9;
        color: #555;
        z-index: 1;
        position: relative;
    }

    .order-id {
        background: rgba(255, 240, 200, 0.5);
        padding: 15px;
        border-radius: 12px;
        margin: 25px 0;
        font-size: 18px;
        font-weight: 600;
        color: #8b7500;
        box-shadow: inset 0 0 10px rgba(255, 230, 150, 0.3);
        z-index: 1;
        position: relative;
    }

    .btn-back {
        background: linear-gradient(135deg, #f9e79f, #f5c469);
        color: #5a4a00;
        padding: 12px 35px;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        margin-top: 20px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(200, 170, 90, 0.3);
        z-index: 1;
        position: relative;
    }

        .btn-back:hover {
            background: linear-gradient(135deg, #f7dc6f, #f4b942);
            transform: translateY(-3px);
            box-shadow: 0 6px 14px rgba(180, 150, 70, 0.4);
        }

    @@keyframes bounceIn {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        50% {
            transform: scale(1.1);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

<div class="success-container">
    <div class="success-icon">✨</div>
    <div class="success-title">Đặt hàng thành công!</div>
    <div class="success-message">
        Cảm ơn bạn đã tin tưởng và lựa chọn sản phẩm của chúng tôi.<br />
        Đơn hàng của bạn đang được xử lý cẩn thận.
    </div>

    @if (!string.IsNullOrEmpty(Model?.OrderId.ToString()))
    {
        <div class="order-id">
            Mã đơn hàng của bạn: <strong>#@Model.OrderId</strong>
        </div>
    }

    <div class="success-message">
        Bạn sẽ nhận được email xác nhận trong vòng <strong>5 phút</strong>.<br />
        Nếu cần hỗ trợ, vui lòng liên hệ bộ phận chăm sóc khách hàng.
    </div>

    <a href="/" class="btn-back">← Tiếp tục mua sắm</a>
</div>

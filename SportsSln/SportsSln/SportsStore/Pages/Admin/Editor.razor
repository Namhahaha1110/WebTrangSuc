@page "/admin/products/edit/{Id:long}"
@page "/admin/products/create"
@inherits OwningComponentBase<IStoreRepository>
<h3 class="mb-3">Thêm phân loại sản phẩm</h3>

<style>
    /* Màu vàng gold */
    :root {
        --gold-main: #d4af37;
        --gold-light: #f6e9c4;
        --gold-dark: #b7992e;
    }

    h3.gold-header {
        background: var(--gold-main);
        color: white;
        border-radius: 6px;
    }

    .gold-card {
        background: #fffdf7;
        border: 1px solid var(--gold-light);
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(212, 175, 55, 0.15);
    }

    .form-label {
        font-weight: 600;
        color: #7a661c;
    }

    input.form-control,
    select.form-select {
        border: 1px solid var(--gold-light);
        border-radius: 8px;
        padding: 10px;
    }

        input.form-control:focus,
        select.form-select:focus {
            border-color: var(--gold-main);
            box-shadow: 0 0 4px rgba(212, 175, 55, 0.5);
        }

    .btn-gold {
        background: var(--gold-main);
        color: white;
        border-radius: 8px;
        border: none;
    }

        .btn-gold:hover {
            background: var(--gold-dark);
            color: white;
        }

    img.preview {
        border: 2px solid var(--gold-light);
        border-radius: 10px;
    }

    div.validation-message {
        color: rgb(220, 53, 69);
        font-weight: 500;
    }

    /* Styles for size management section */
    .size-section {
        background: #fffaf2;
        border: 1px solid var(--gold-light);
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
    }

    .size-item {
        background: white;
        border: 1px solid #e5d5a8;
        border-radius: 6px;
        padding: 10px;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-remove-size {
        background: #dc3545;
        color: white;
        border: none;
        border-radius: 4px;
        padding: 5px 10px;
        cursor: pointer;
    }

        .btn-remove-size:hover {
            background: #c82333;
        }

    .btn-add-size {
        background: #28a745;
        color: white;
        border: none;
        border-radius: 4px;
        padding: 8px 15px;
        cursor: pointer;
    }

        .btn-add-size:hover {
            background: #218838;
        }
</style>

<h3 class="gold-header text-center py-2 mb-3">
    @TitleText a Product
</h3>

<div class="card gold-card p-4">
    <EditForm Model="Product" OnValidSubmit="SaveProduct">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @if (Product.ProductID != 0)
        {
            <div class="mb-3">
                <label class="form-label">ID</label>
                <input class="form-control" disabled value="@Product.ProductID" />
            </div>
        }

        <div class="mb-3">
            <label class="form-label">Name</label>
            <InputText class="form-control" @bind-Value="Product.Name" />
            <ValidationMessage For="@(() => Product.Name)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputText class="form-control" @bind-Value="Product.Description" />
            <ValidationMessage For="@(() => Product.Description)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Ảnh sản phẩm</label>
            <InputFile OnChange="OnFileSelected" />

            @if (!string.IsNullOrEmpty(PreviewImage))
            {
                <div class="mt-2">
                    <img src="@PreviewImage" alt="Preview" width="170"
                         class="preview" style="object-fit:cover;" />
                </div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>
            <InputSelect class="form-select" @bind-Value="Product.CategoryID" TValue="long?">
                <option value="0">-- Chọn phân loại --</option>
                @foreach (var cat in CategoryData)
                {
                    <option value="@cat.CategoryID">@cat.Name</option>
                }
            </InputSelect>
            <ValidationMessage For="@(() => Product.CategoryID)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Price</label>
            <InputNumber class="form-control" @bind-Value="Product.Price" />
            <ValidationMessage For="@(() => Product.Price)" />
        </div>

        <!-- Add Quantity field -->
        <div class="mb-3">
            <label class="form-label">Số lượng (Quantity)</label>
            <InputNumber class="form-control" @bind-Value="Product.Quantity" />
            <small class="text-muted">Nếu bằng 0 thì sản phẩm sẽ ẩn khỏi danh sách khách hàng</small>
            <ValidationMessage For="@(() => Product.Quantity)" />
        </div>


        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-gold px-4">Save</button>
            <NavLink class="btn btn-secondary px-4" href="/admin/products">Cancel</NavLink>
        </div>
    </EditForm>
</div>

@code {
    public IStoreRepository Repository => Service;

    [Inject] public NavigationManager? NavManager { get; set; }

    [Parameter] public long Id { get; set; } = 0;

    public Product Product { get; set; } = new Product();
    public IEnumerable<Category> CategoryData { get; set; } = Enumerable.Empty<Category>();

    private string? NewSizeInput;

    private IBrowserFile? UploadedFile;
    private string? PreviewImage;

    protected override async Task OnInitializedAsync()
    {
        CategoryData = await Repository.Categories.ToListAsync();

        if (Id != 0)
        {
            Product = await Repository.Products
                        .FirstOrDefaultAsync(p => p.ProductID == Id)
                      ?? new Product();

            if (!string.IsNullOrEmpty(Product.ImageUrl))
            {
                PreviewImage = $"images/{Product.ImageUrl}";
            }
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        UploadedFile = e.File;

        var buffer = new byte[UploadedFile.Size];
        await UploadedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
        var base64 = Convert.ToBase64String(buffer);
        var format = UploadedFile.ContentType;
        PreviewImage = $"data:{format};base64,{base64}";
    }


    public async Task SaveProduct()
    {
        if (Product.CategoryID == null || Product.CategoryID == 0)
        {
            return;
        }

        if (UploadedFile != null)
        {
            var fileName = $"{Guid.NewGuid()}{Path.GetExtension(UploadedFile.Name)}";
            var savePath = Path.Combine("wwwroot", "images", fileName);

            await using var stream = new FileStream(savePath, FileMode.Create);
            await UploadedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(stream);

            Product.ImageUrl = fileName;
        }

        if (Id == 0)
        {
            await Repository.CreateProduct(Product);
        }
        else
        {
            await Repository.SaveProduct(Product);
        }

        NavManager?.NavigateTo("/admin/products");
    }

    public string ThemeColor => Id == 0 ? "primary" : "warning";
    public string TitleText => Id == 0 ? "Create" : "Edit";
}

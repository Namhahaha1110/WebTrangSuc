    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Slideshow
        (function () {
            const container = document.getElementById('mainSlideshow');
            if (!container) return;
            const slides = Array.from(container.querySelectorAll('.sliding-image'));
            const buttons = Array.from(container.querySelectorAll('.controls .button'));
            if (slides.length === 0 || buttons.length === 0) return;
            let index = 0;
            let timer;

            function showSlide(i) {
                slides.forEach((s, idx) => s.classList.toggle('active', idx === i));
                buttons.forEach((b, idx) => b.classList.toggle('active', idx === i));
                index = i;
            }

            function next() {
                showSlide((index + 1) % slides.length);
            }

            function start() {
                stop();
                timer = setInterval(next, 2000);
            }

            function stop() {
                if (timer) clearInterval(timer);
            }

            buttons.forEach((b, i) => {
                b.addEventListener('click', () => {
                    showSlide(i);
                    start();
                });
            });

            container.addEventListener('mouseenter', stop);
            container.addEventListener('mouseleave', start);

            showSlide(0);
            start();
        })();
    </script>

    @RenderSection("Scripts", required: false)

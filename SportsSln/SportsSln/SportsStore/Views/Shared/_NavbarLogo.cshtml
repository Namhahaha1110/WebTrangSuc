@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var nameCus = HttpContextAccessor.HttpContext?.Session.GetString("CustomerName");
}


<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm" style="padding: 3px 0; min-height: 50px;">
    <div class="container d-flex justify-content-between align-items-center">
        <!-- Nút thu gọn khi màn hình nhỏ -->
        <button class="navbar-toggler" type="button" data-toggle="collapse"
                data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false"
                aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Logo -->
        <a class="navbar-brand logo ml-2" asp-controller="Home" asp-action="Index">
            <img src="https://i.pinimg.com/736x/73/fb/de/73fbde1145fa156318b20b494536e34f.jpg"
                 alt="Logo" style="height: 45px; margin-left: 5px;" />
        </a>

        <div class="collapse navbar-collapse" id="navbarNav">
            <!-- Menu bên trái -->
            <ul class="navbar-nav mr-auto d-flex align-items-center" style="font-size: 14px;">
                <li class="nav-item mr-2">
                    <a class="nav-link" asp-controller="QuanHeCoDong" asp-action="Index">
                        <i class="fa-solid fa-handshake"></i> Quan hệ cổ đông
                    </a>
                </li>
                <li class="nav-item mr-2">
                    <a class="nav-link" asp-controller="CuaHang" asp-action="Index">
                        <i class="fa-solid fa-store"></i> Cửa hàng
                    </a>
                </li>
                <li class="nav-item mr-2">
                    <a class="nav-link" asp-controller="TinTuc" asp-action="Index">
                        <i class="fa-solid fa-newspaper"></i> Tin tức
                    </a>
                </li>
            </ul>

            <!-- Menu bên phải -->
            <ul class="nav navbar-nav navbar-right d-flex align-items-center" style="font-size: 14px;">
                <li class="nav-item mr-3">
                    <a href="tel:190012345" class="text-dark text-decoration-none">
                        <i class="fas fa-phone-alt"></i> 1900 12345
                    </a>
                </li>
                <li class="nav-item mr-3">
                    <a href="mailto:FlowerJewelry@gmail.com" class="text-dark text-decoration-none">
                        <i class="fas fa-envelope"></i> FlowerJewelry@gmail.com
                    </a>
                </li>
                <li class="nav-item dropdown ml-2">
                    @if (!string.IsNullOrEmpty(nameCus))
                    {
                        <!-- ✅ Nếu đã đăng nhập -->
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" id="accountDropdown"
                                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            👤 @nameCus
                        </button>
                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="accountDropdown">
                             <a class="nav-link" asp-controller="CustomerAccount" asp-action="MyAccount">
                                <i class="fas fa-user-circle"></i> Tài khoản của tôi
                            </a>
                            <form asp-controller="CustomerAccount" asp-action="Logout" method="post" class="m-0">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt"></i> Đăng xuất
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <!-- ❌ Nếu chưa đăng nhập -->
                        <button class="btn btn-outline-primary btn-sm dropdown-toggle" type="button" id="guestDropdown"
                                data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            <i class="fa fa-user"></i> Tài khoản
                        </button>
                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="guestDropdown">
                            <a class="dropdown-item" asp-controller="CustomerAccount" asp-action="Login">
                                <i class="fa fa-sign-in-alt"></i> Đăng nhập
                            </a>
                            <a class="dropdown-item" asp-controller="CustomerAccount" asp-action="Register">
                                <i class="fa fa-user-plus"></i> Đăng ký
                            </a>
                        </div>
                    }
                </li>
            </ul>
        </div>
    </div>

</nav> <!-- ================= CSS & JS ================= -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css"> <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script> <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
<style>
    .navbar-nav .nav-link {
        padding-top: 2px !important;
        padding-bottom: 2px !important;
    }

    .navbar {
        font-size: 14px;
    }

    .dropdown-menu a:hover {
        background-color: #f8f9fa;
    }
</style>
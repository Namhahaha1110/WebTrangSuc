<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
    /* ==== TOÀN TRANG ==== */
    body {
        font-family: 'Segoe UI', sans-serif;
        background-color: #fffdf7;
        color: #333;
        margin: 0;
        padding: 0;
    }

    .shareholder-container {
        max-width: 1250px;
        margin: 60px auto;
        padding: 0 4cm; /* cách lề trái phải 4cm */
        animation: fadeIn 1s ease;
    }

    /* ==== BANNER ẢNH ĐẦU TRANG ==== */
    .page-banner {
        width: 100%;
        max-height: 300px;
        overflow: hidden;
        border-radius: 12px;
        box-shadow: 0 4px 12px rgba(184, 134, 11, 0.2);
        margin-bottom: 40px;
    }

        .page-banner img {
            width: 100%;
            height: auto;
            display: block;
            object-fit: cover;
        }

    /* ==== TIÊU ĐỀ ==== */
    .shareholder-title {
        text-align: center;
        color: #b8860b;
        font-size: 36px;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 50px;
        text-transform: uppercase;
        position: relative;
    }

        .shareholder-title::after {
            content: "";
            display: block;
            width: 80px;
            height: 3px;
            background-color: #b8860b;
            margin: 15px auto 0;
            border-radius: 3px;
        }

    /* ==== THẺ NỘI DUNG ==== */
    .shareholder-card {
        background-color: #fffaf0;
        border-radius: 15px;
        box-shadow: 0 4px 12px rgba(184, 134, 11, 0.2);
        margin-bottom: 25px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .shareholder-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 18px rgba(184, 134, 11, 0.3);
        }

    .card-header {
        background: linear-gradient(90deg, #b8860b, #e6c97a);
        color: white;
        padding: 18px 25px;
        font-size: 20px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .card-header:hover {
            background: linear-gradient(90deg, #a87e0b, #e3c76b);
        }

        .card-header i {
            transition: transform 0.3s ease;
        }

        .card-header.active i {
            transform: rotate(180deg);
        }

    .card-content {
        display: none;
        padding: 25px 30px;
        font-size: 17px;
        line-height: 1.8;
        color: #444;
        background-color: #fff;
        animation: fadeIn 0.4s ease;
    }

        .card-content p {
            margin-bottom: 10px;
        }

        .card-content a {
            color: #b8860b;
            text-decoration: none;
            font-weight: 600;
        }

            .card-content a:hover {
                text-decoration: underline;
            }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>


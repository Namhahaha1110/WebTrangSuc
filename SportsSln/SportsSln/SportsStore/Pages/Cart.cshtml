                            <input type="text" id="buyerName" name="Name" class="form-input"
                                   placeholder="Nguyễn Văn An"
                                   value="@Model.PrefillName"
                                   autocomplete="name"
                                   required />
                        </div>
                        <div class="form-field">
                            <label class="form-label field-required" for="buyerPhone">Số điện thoại</label>
                            <input type="tel" id="buyerPhone" name="Phone" class="form-input"
                                   placeholder="0912 345 678"
                                   value="@Model.PrefillPhone"
                                   autocomplete="tel"
                                   required />
                        </div>
                        <div class="form-field" style="grid-column: 1 / -1">
                            <label class="form-label field-required" for="buyerEmail">Email</label>
                            <input type="email" id="buyerEmail" name="Email" class="form-input"
                                   placeholder="email@example.com"
                                   value="@Model.PrefillEmail"
                                   autocomplete="email"
                                   required />
                        </div>
                    </div>
                </div>

                <!-- ── 3. Delivery Method ── -->
                <div class="cart-section">
                    <div class="section-hd">
                        <div class="section-hd__icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="1" y="3" width="15" height="13"/>
                                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                            </svg>
                        </div>
                        <h2 class="section-hd__title">Hình thức nhận hàng</h2>
                    </div>

                    <input type="hidden" name="DeliveryType" id="deliveryTypeInput" value="delivery" />

                    <div class="delivery-options" role="group" aria-label="Chọn hình thức nhận hàng">
                        <button type="button" id="btnDelivery" class="delivery-btn active" aria-pressed="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <rect x="1" y="3" width="15" height="13"/>
                                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                            </svg>
                            Giao hàng tận nơi
                        </button>
                        <button type="button" id="btnPickup" class="delivery-btn" aria-pressed="false">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                <polyline points="9 22 9 12 15 12 15 22"/>
                            </svg>
                            Nhận tại cửa hàng
                        </button>
                    </div>

                    <!-- Delivery address form -->
                    <div id="deliveryForm" style="margin-top: var(--space-5);">
                        <div class="form-grid">
                            <div class="form-field">
                                <label class="form-label field-required" for="province">Tỉnh / Thành phố</label>
                                <select name="Province" id="province" class="form-select"
                                        data-saved="" data-prefill="@Model.PrefillProvince">
                                    <option value="">Chọn tỉnh/thành *</option>
                                </select>
                            </div>
                            <div class="form-field">
                                <label class="form-label field-required" for="district">Quận / Huyện</label>
                                <select name="District" id="district" class="form-select"
                                        data-saved="" data-prefill="@Model.PrefillDistrict">
                                    <option value="">Chọn quận/huyện *</option>
                                </select>
                            </div>
                            <div class="form-field">
                                <label class="form-label field-required" for="ward">Phường / Xã</label>
                                <select name="Ward" id="ward" class="form-select"
                                        data-saved="" data-prefill="@Model.PrefillWard">
                                    <option value="">Chọn phường/xã *</option>
                                </select>
                            </div>
                            <div class="form-field">
                                <label class="form-label field-required" for="addressDetail">Địa chỉ cụ thể</label>
                                <input type="text" id="addressDetail" name="AddressDetail" class="form-input"
                                       placeholder="Số nhà, tên đường..."
                                       value="@Model.PrefillAddressDetail"
                                       data-saved=""
                                       autocomplete="street-address" />
                            </div>
                        </div>
                    </div>

                    <!-- Pickup store form -->
                    <div id="pickupForm" style="display:none; margin-top: var(--space-5);">
                        <div class="form-grid">
                            <div class="form-field">
                                <label class="form-label field-required" for="citySelect">Thành phố</label>
                                <select id="citySelect" name="City" class="form-select" data-saved="">
                                    <option value="">— Chọn Thành Phố —</option>
                                    <option value="hcm">Hồ Chí Minh</option>
                                    <option value="hn">Hà Nội</option>
                                    <option value="dn">Đà Nẵng</option>
                                    <option value="dnai">Đồng Nai</option>
                                    <option value="ld">Lâm Đồng</option>
                                    <option value="bd">Bình Dương</option>
                                    <option value="ct">Cần Thơ</option>
                                    <option value="tth">Thừa Thiên Huế</option>
                                </select>
                            </div>
                            <div class="form-field">
                                <label class="form-label field-required" for="districtSelect">Quận / Huyện</label>
                                <select id="districtSelect" name="DistrictPickup" class="form-select" data-saved="" disabled>
                                    <option value="">— Chọn Quận/Huyện —</option>
                                </select>
                            </div>
                            <div class="form-field" style="grid-column: 1 / -1">
                                <label class="form-label field-required" for="storeSelect">Cửa hàng</label>
                                <select id="storeSelect" name="Store" class="form-select" data-saved="" disabled>
                                    <option value="">— Chọn Cửa Hàng —</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── 4. Payment Method ── -->
                <div class="cart-section">
                    <div class="section-hd">
                        <div class="section-hd__icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                                <line x1="1" y1="10" x2="23" y2="10"/>
                            </svg>
                        </div>
                        <h2 class="section-hd__title">Phương thức thanh toán</h2>
                    </div>

                    <div class="payment-options" role="radiogroup" aria-label="Chọn phương thức thanh toán">
                        <label class="payment-option">
                            <input type="radio" name="Payment" value="COD" checked />
                            <div>
                                <div class="payment-option__text">Thanh toán khi nhận hàng (COD)</div>
                                <div class="payment-option__sub">Trả tiền mặt khi nhận được hàng</div>
                            </div>
                        </label>
                        <label class="payment-option">
                            <input type="radio" name="Payment" value="VNPAY" />
                            <div>
                                <div class="payment-option__text">Thanh toán online qua VNPAY</div>
                                <div class="payment-option__sub">ATM, Visa, QR Code</div>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- ── 5. Note ── -->
                <div class="cart-section">
                    <div class="form-field">
                        <label class="form-label" for="orderNote">Ghi chú đơn hàng</label>
                        <textarea id="orderNote" name="Note" class="form-textarea"
                                  placeholder="VD: Giao giờ hành chính, gọi điện trước khi giao..."></textarea>
                    </div>
                </div>

                <!-- Validation errors (inline) -->
                <div id="formErrors" class="form-errors" role="alert" aria-live="assertive"></div>
            </form>
        </div>

        <!-- ══ RIGHT: Order Summary ══ -->
        <aside class="cart-sidebar" aria-label="Tóm tắt đơn hàng">
            <div class="order-summary">
                <h2 class="order-summary__title">Tóm tắt đơn hàng</h2>

                <div class="summary-row">
                    <span>Tạm tính</span>
                    <span id="subtotal">@Model.ShoppingCart.ComputeTotalValue().ToString("N0", cultureVN) VNĐ</span>
                </div>
                <div class="summary-row">
                    <span>Phí giao hàng</span>
                    <span class="shipping-free">
                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>

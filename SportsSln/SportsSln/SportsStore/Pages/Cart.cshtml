@page
@model SportsStore.Pages.CartModel
@{
    ViewData["Title"] = "Giỏ hàng — Flower Jewelry";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cultureVN = new System.Globalization.CultureInfo("vi-VN");
    var hasItems  = Model?.ShoppingCart?.Lines?.Any() ?? false;
}

<style>
    /* ════════════════════════════════════════════════════
       CART — PAGE HEADER
    ════════════════════════════════════════════════════ */
    .cart-page-header {
        text-align:     center;
        padding:        var(--space-10) 0 var(--space-8);
    }
    .cart-page-eyebrow {
        display:        block;
        font-family:    var(--font-body);
        font-size:      11px;
        font-weight:    600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color:          var(--color-accent);
        margin-bottom:  var(--space-2);
    }
    .cart-page-title {
        font-family:  var(--font-heading);
        font-size:    clamp(28px, 5vw, 42px);
        font-weight:  700;
        color:        var(--color-foreground);
        margin:       0 0 var(--space-3);
        line-height:  1.1;
    }
    .cart-page-sep {
        width:      60px; height: 1.5px;
        background: linear-gradient(to right, transparent, var(--color-accent-light), transparent);
        margin:     0 auto;
    }

    /* ════════════════════════════════════════════════════
       EMPTY STATE
    ════════════════════════════════════════════════════ */
    .cart-empty {
        text-align:     center;
        padding:        var(--space-20) var(--space-4);
        display:        flex;
        flex-direction: column;
        align-items:    center;
        gap:            var(--space-4);
    }
    .cart-empty__icon {
        width: 88px; height: 88px;
        border-radius: var(--radius-full);
        background:    rgba(161,98,7,0.08);
        display:       flex; align-items: center; justify-content: center;
        color:         var(--color-accent-light);
    }
    .cart-empty__icon svg { width: 42px; height: 42px; }
    .cart-empty__title {
        font-family: var(--font-heading);
        font-size:   30px;
        font-weight: 700;
        color:       var(--color-foreground);
        margin:      0;
    }
    .cart-empty__desc {
        font-size:   15px;
        color:       var(--color-text-secondary);
        max-width:   360px;
        line-height: 1.7;
        margin:      0;
    }
    .btn-go-shop {
        display:         inline-flex;
        align-items:     center;
        gap:             var(--space-2);
        padding:         var(--space-3) var(--space-8);
        min-height:      48px;
        border-radius:   var(--radius-full);
        background:      var(--color-primary);
        color:           var(--color-accent-light);
        font-family:     var(--font-body);
        font-size:       13px;
        font-weight:     600;
        letter-spacing:  1px;
        text-transform:  uppercase;
        text-decoration: none;
        border:          1.5px solid rgba(212,175,55,0.25);
        transition:      background var(--dur-normal), box-shadow var(--dur-normal), transform var(--dur-fast);
        touch-action:    manipulation;
    }
    .btn-go-shop:hover {
        background:  var(--color-secondary);
        box-shadow:  var(--shadow-gold);
        transform:   translateY(-2px);
        color:       var(--color-accent-light);
    }
    .btn-go-shop:focus-visible { outline: 2px solid var(--color-accent-light); outline-offset: 3px; }

    /* ════════════════════════════════════════════════════
       CART LAYOUT — 2 cột desktop
    ════════════════════════════════════════════════════ */
    .cart-layout {
        display:     grid;
        gap:         var(--space-8);
        grid-template-columns: 1fr;
        align-items: start;
        padding-bottom: var(--space-16);
    }
    @@media (min-width: 992px) {
        .cart-layout { grid-template-columns: 1fr 360px; }
    }

    /* ════════════════════════════════════════════════════
       CART SECTIONS
    ════════════════════════════════════════════════════ */
    .cart-section {
        background:    white;
        border-radius: var(--radius-xl);
        border:        1px solid var(--color-border-subtle);
        padding:       var(--space-6);
        margin-bottom: var(--space-5);
    }
    .cart-section:last-child { margin-bottom: 0; }

    .section-hd {
        display:       flex;
        align-items:   center;
        gap:           var(--space-3);
        margin-bottom: var(--space-5);
        padding-bottom: var(--space-4);
        border-bottom: 1px solid var(--color-border-subtle);
    }
    .section-hd__icon {
        width: 36px; height: 36px;
        border-radius: var(--radius-full);
        background:    rgba(161,98,7,0.08);
        display:       flex; align-items: center; justify-content: center;
        color:         var(--color-accent-light);
        flex-shrink:   0;
    }
    .section-hd__title {
        font-family:  var(--font-heading);
        font-size:    20px;
        font-weight:  700;
        color:        var(--color-foreground);
        margin:       0;
    }

    /* ════════════════════════════════════════════════════
       CART ITEMS — Product rows
    ════════════════════════════════════════════════════ */
    .product-item {
        display:       flex;
        align-items:   center;
        gap:           var(--space-4);
        padding:       var(--space-4) 0;
        border-bottom: 1px solid var(--color-border-subtle);
    }
    .product-item:last-child { border-bottom: none; padding-bottom: 0; }
    .product-item:first-child { padding-top: 0; }

    /* Custom checkbox */
    .product-checkbox {
        width:        22px; height: 22px;
        accent-color: var(--color-accent-light);
        cursor:       pointer;
        flex-shrink:  0;
        border-radius: 4px;
    }

    .product-left {
        display:     flex;
        align-items: center;
        gap:         var(--space-3);
        flex:        1;
        min-width:   0;
    }
    .product-left img {
        width:         80px; height: 80px;
        border-radius: var(--radius-lg);
        object-fit:    contain;
        background:    #FAF8F3;
        border:        1px solid var(--color-border-subtle);
        padding:       var(--space-2);
        flex-shrink:   0;
    }
    .product-details { display: flex; flex-direction: column; gap: var(--space-1); min-width: 0; }
    .product-name {
        font-family:  var(--font-heading);
        font-size:    17px;
        font-weight:  600;
        color:        var(--color-foreground);
        white-space:  nowrap;
        overflow:     hidden;
        text-overflow: ellipsis;
    }
    .product-code { font-size: 12px; color: var(--color-text-secondary); letter-spacing: 0.5px; }

    /* Quantity stepper in cart */
    .quantity-group {
        display:  flex;
        align-items: center;
        gap:      var(--space-1);
        margin-top: var(--space-2);
    }
    .quantity-btn {
        width: 32px; height: 32px;
        background:    white;
        border:        1.5px solid var(--color-border);
        border-radius: var(--radius-full);
        font-size:     16px;
        color:         var(--color-secondary);
        cursor:        pointer;
        display:       flex;
        align-items:   center;
        justify-content: center;
        transition:    background var(--dur-fast), color var(--dur-fast), border-color var(--dur-fast);
        touch-action:  manipulation;
        line-height:   1;
    }
    .quantity-btn:hover {
        background:   var(--color-accent-light);
        border-color: var(--color-accent-light);
        color:        var(--color-primary);
    }
    .quantity-btn:focus-visible { outline: 2px solid var(--color-accent-light); outline-offset: 2px; }
    .quantity-input {
        width:         48px; height: 32px;
        text-align:    center;
        border:        1.5px solid var(--color-border);
        border-radius: var(--radius-md);
        font-size:     14px;
        font-weight:   600;
        font-family:   var(--font-body);
        color:         var(--color-foreground);
        -moz-appearance: textfield;
    }
    .quantity-input::-webkit-outer-spin-button,
    .quantity-input::-webkit-inner-spin-button { -webkit-appearance: none; }

    .product-actions {
        display:     flex;
        gap:         var(--space-4);
        align-items: center;
        flex-shrink: 0;
    }
    .product-price {
        font-family:    var(--font-heading);
        font-size:      18px;
        font-weight:    700;
        color:          var(--color-accent);
        font-variant-numeric: tabular-nums;
        white-space:    nowrap;
        min-width:      110px;
        text-align:     right;
    }
    .btn-delete {
        width: 36px; height: 36px;
        background:    transparent;
        border:        1.5px solid rgba(239,68,68,0.25);
        border-radius: var(--radius-full);
        color:         #DC2626;
        cursor:        pointer;
        display:       flex;
        align-items:   center;
        justify-content: center;
        transition:    background var(--dur-fast), border-color var(--dur-fast);
        touch-action:  manipulation;
        flex-shrink:   0;
    }
    .btn-delete:hover { background: rgba(239,68,68,0.08); border-color: #DC2626; }
    .btn-delete:focus-visible { outline: 2px solid #DC2626; outline-offset: 2px; }

    /* ════════════════════════════════════════════════════
       FORM — Inputs, Labels
    ════════════════════════════════════════════════════ */
    .form-grid {
        display:               grid;
        gap:                   var(--space-4);
        grid-template-columns: 1fr;
    }
    @@media (min-width: 576px) {
        .form-grid--2col { grid-template-columns: 1fr 1fr; }
    }

    .form-field {
        display:        flex;
        flex-direction: column;
        gap:            var(--space-1);
    }
    .form-label {
        font-family:   var(--font-body);
        font-size:     12px;
        font-weight:   600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color:         var(--color-secondary);
    }
    .field-required::after { content: " *"; color: var(--color-destructive); }

    .form-input,
    .form-select,
    .form-textarea {
        border:        1.5px solid var(--color-border);
        border-radius: var(--radius-md);
        padding:       var(--space-3) var(--space-4);
        font-size:     15px;
        font-family:   var(--font-body);
        color:         var(--color-foreground);
        background:    white;
        width:         100%;
        min-height:    48px;
        transition:    border-color var(--dur-fast), box-shadow var(--dur-fast);
        outline:       none;
        appearance:    none;
    }
    .form-input:focus,
    .form-select:focus,
    .form-textarea:focus {
        border-color: var(--color-accent-light);
        box-shadow:   0 0 0 3px rgba(212,175,55,0.12);
    }
    .form-input::placeholder { color: var(--color-text-secondary); font-size: 14px; }
    .form-textarea { min-height: 80px; resize: vertical; line-height: 1.6; }
    .form-select:disabled { background: var(--color-bg-subtle); opacity: 0.6; }

    /* ════════════════════════════════════════════════════
       DELIVERY METHOD — Toggle buttons
    ════════════════════════════════════════════════════ */
    .delivery-options {
        display: flex;
        gap:     var(--space-3);
    }
    .delivery-btn {
        flex:          1;
        min-height:    52px;
        padding:       var(--space-3) var(--space-4);
        border:        1.5px solid var(--color-border);
        border-radius: var(--radius-lg);
        background:    white;
        color:         var(--color-secondary);
        font-family:   var(--font-body);
        font-size:     14px;
        font-weight:   500;
        cursor:        pointer;
        transition:    all var(--dur-normal) var(--ease-out);
        display:       flex;
        align-items:   center;
        justify-content: center;
        gap:           var(--space-2);
        touch-action:  manipulation;
    }
    .delivery-btn:hover {
        border-color: var(--color-accent-light);
        color:        var(--color-accent);
    }
    .delivery-btn.active {
        background:   var(--color-primary);
        border-color: var(--color-primary);
        color:        var(--color-accent-light);
        box-shadow:   var(--shadow-md);
    }
    .delivery-btn:focus-visible { outline: 2px solid var(--color-accent-light); outline-offset: 2px; }

    @@media (max-width: 480px) {
        .delivery-options { flex-direction: column; }
    }

    /* ════════════════════════════════════════════════════
       PAYMENT METHOD — Card style
    ════════════════════════════════════════════════════ */
    .payment-options { display: flex; flex-direction: column; gap: var(--space-3); }
    .payment-option {
        display:     flex;
        align-items: center;
        gap:         var(--space-3);
        padding:     var(--space-4) var(--space-5);
        border:      1.5px solid var(--color-border);
        border-radius: var(--radius-lg);
        cursor:      pointer;
        transition:  border-color var(--dur-fast), background var(--dur-fast);
    }
    .payment-option:has(input:checked) {
        border-color: var(--color-accent-light);
        background:   rgba(212,175,55,0.05);
    }
    .payment-option input[type="radio"] {
        width: 18px; height: 18px;
        accent-color: var(--color-accent-light);
        cursor:       pointer;
        flex-shrink:  0;
    }
    .payment-option__text {
        font-family: var(--font-body);
        font-size:   14px;
        font-weight: 500;
        color:       var(--color-foreground);
    }
    .payment-option__sub {
        font-size:   12px;
        color:       var(--color-text-secondary);
        margin-top:  2px;
    }

    /* ════════════════════════════════════════════════════
       VALIDATION ERRORS
    ════════════════════════════════════════════════════ */
    .form-errors {
        display:       none;
        padding:       var(--space-4) var(--space-5);
        border-radius: var(--radius-lg);
        background:    rgba(239,68,68,0.06);
        border:        1.5px solid rgba(239,68,68,0.2);
        color:         #B91C1C;
        font-size:     14px;
        line-height:   1.6;
        margin-bottom: var(--space-4);
    }
    .form-errors ul { list-style: none; padding: 0; margin: 0; }
    .form-errors li::before { content: "• "; font-weight: 700; }
    .form-errors__title { font-weight: 700; margin-bottom: var(--space-2); }

    .payment-error-alert {
        display:       flex;
        align-items:   flex-start;
        gap:           var(--space-3);
        padding:       var(--space-4) var(--space-5);
        border-radius: var(--radius-lg);
        background:    rgba(245,158,11,0.08);
        border:        1.5px solid rgba(245,158,11,0.25);
        color:         #92400E;
        font-size:     14px;
        margin-bottom: var(--space-4);
    }

    /* ════════════════════════════════════════════════════
       CART SIDEBAR — Summary (sticky)
    ════════════════════════════════════════════════════ */
    .cart-sidebar { position: sticky; top: 90px; }

    .order-summary {
        background:    white;
        border-radius: var(--radius-xl);
        border:        1px solid var(--color-border-subtle);
        padding:       var(--space-6);
        overflow:      hidden;
    }
    .order-summary__title {
        font-family:   var(--font-heading);
        font-size:     22px;
        font-weight:   700;
        color:         var(--color-foreground);
        margin:        0 0 var(--space-5);
        padding-bottom: var(--space-4);
        border-bottom: 1px solid var(--color-border-subtle);
    }

    .summary-row {
        display:         flex;
        justify-content: space-between;
        align-items:     center;
        padding:         var(--space-3) 0;
        font-size:       15px;
        color:           var(--color-secondary);
        border-bottom:   1px solid var(--color-border-subtle);
    }
    .summary-row:last-of-type { border-bottom: none; }
    .summary-row span:first-child { color: var(--color-text-secondary); }
    .summary-row--total {
        padding-top: var(--space-4);
        font-weight: 700;
        font-size:   17px;
    }
    .summary-row--total span:first-child {
        font-family: var(--font-heading);
        color:       var(--color-foreground);
        font-size:   18px;
    }
    #subtotal, #total {
        font-family:    var(--font-heading);
        font-size:      18px;
        font-weight:    700;
        color:          var(--color-accent);
        font-variant-numeric: tabular-nums;
    }
    #total { font-size: 22px; }

    .shipping-free {
        display:     inline-flex;
        align-items: center;
        gap:         var(--space-1);
        font-size:   13px;
        font-weight: 600;
        color:       #15803D;
    }

    .btn-order {
        display:       flex;
        align-items:   center;
        justify-content: center;
        gap:           var(--space-2);
        width:         100%;
        min-height:    54px;
        background:    linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
        color:         var(--color-primary);
        font-family:   var(--font-body);
        font-size:     14px;
        font-weight:   700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        border:        none;
        border-radius: var(--radius-full);
        cursor:        pointer;
        margin-top:    var(--space-5);
        transition:    transform var(--dur-fast), box-shadow var(--dur-fast);
        touch-action:  manipulation;
    }
    .btn-order:hover {
        transform:  translateY(-2px);
        box-shadow: var(--shadow-gold);
    }
    .btn-order:focus-visible { outline: 2px solid var(--color-accent-light); outline-offset: 3px; }

    .summary-note {
        margin-top:  var(--space-4);
        font-size:   12px;
        color:       var(--color-text-secondary);
        text-align:  center;
        line-height: 1.6;
    }

    /* ════════════════════════════════════════════════════
       VOUCHER — Luxury Cart Add-on
    ════════════════════════════════════════════════════ */
    .voucher-container {
        margin-top: var(--space-4);
        padding-top: var(--space-4);
        border-top: 1px dashed var(--color-border-subtle);
    }
    .voucher-title {
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--color-secondary);
        display: flex;
        align-items: center;
        gap: var(--space-2);
        margin-bottom: var(--space-3);
    }
    .voucher-title svg { color: var(--color-accent); }
    .voucher-form {
        display: flex;
        gap: var(--space-2);
    }
    .voucher-input {
        flex: 1;
        min-width: 0;
        height: 48px;
        border: 1.5px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 0 var(--space-3);
        font-size: 14px;
        font-weight: 500;
        text-transform: uppercase;
        color: var(--color-foreground);
        transition: all var(--dur-fast);
        background: #FAF8F3;
    }
    .voucher-input:focus {
        border-color: var(--color-accent-light);
        box-shadow: 0 0 0 3px rgba(212,175,55,0.12);
        background: white;
        outline: none;
    }
    .voucher-input::placeholder {
        text-transform: none;
        font-weight: 400;
        color: var(--color-text-secondary);
    }
    .btn-voucher {
        height: 48px;
        padding: 0 var(--space-4);
        border-radius: var(--radius-md);
        background: var(--color-primary);
        color: var(--color-accent-light);
        font-family: var(--font-body);
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.5px;
        border: 1.5px solid rgba(212,175,55,0.25);
        cursor: pointer;
        transition: all var(--dur-normal);
    }
    .btn-voucher:hover {
        background: var(--color-secondary);
        box-shadow: var(--shadow-sm);
        border-color: var(--color-accent);
    }
    .btn-voucher:active { transform: translateY(1px); }

    .summary-row--discount {
        color: #15803D; /* Success green */
        font-weight: 600;
        display: none;
    }
    .summary-row--discount span:last-child {
        font-variant-numeric: tabular-nums;
    }

    .voucher-applied {
        display: none;
        align-items: center;
        justify-content: space-between;
        padding: var(--space-3);
        background: rgba(21, 128, 61, 0.05);
        border: 1px solid rgba(21, 128, 61, 0.15);
        border-radius: var(--radius-md);
        margin-top: var(--space-2);
    }
    .voucher-applied-info {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        color: #15803D;
        font-size: 13px;
        font-weight: 600;
    }
    .btn-remove-voucher {
        background: transparent;
        border: none;
        padding: 4px;
        cursor: pointer;
        color: var(--color-text-secondary);
        transition: color var(--dur-fast);
        display: flex;
    }
    .btn-remove-voucher:hover {
        color: #DC2626;
    }

    /* ════════════════════════════════════════════════════
       TOAST (reuse từ Details)
    ════════════════════════════════════════════════════ */
    .toast-container {
        position: fixed;
        bottom: var(--space-6); right: var(--space-5);
        z-index: var(--z-toast);
        display: flex; flex-direction: column;
        gap: var(--space-3); pointer-events: none;
    }
    .toast {
        display:    flex; align-items: flex-start;
        gap:        var(--space-3);
        padding:    var(--space-4) var(--space-5);
        border-radius: var(--radius-lg);
        background: white;
        box-shadow: var(--shadow-xl);
        border-left: 4px solid var(--color-accent-light);
        min-width: 260px; max-width: 340px;
        pointer-events: auto;
        animation: toastIn 250ms var(--ease-out);
    }
    .toast--error   { border-left-color: #DC2626; }
    .toast--success { border-left-color: #22C55E; }
    @@keyframes toastIn {
        from { opacity: 0; transform: translateX(16px); }
        to   { opacity: 1; transform: translateX(0); }
    }
    @@keyframes toastOut {
        from { opacity: 1; transform: translateX(0); }
        to   { opacity: 0; transform: translateX(16px); }
    }
    .toast__msg { font-size: 14px; line-height: 1.5; color: var(--color-foreground); flex: 1; }
    .toast__msg strong { display: block; font-weight: 600; margin-bottom: 2px; }

    /* ════════ RESPONSIVE ════════ */
    @@media (max-width: 767.98px) {
        .product-item {
            flex-wrap:   wrap;
            align-items: flex-start;
        }
        .product-actions {
            width:           100%;
            justify-content: space-between;
            padding-left:    calc(22px + var(--space-4) + 80px + var(--space-3));
        }
        .product-price { min-width: 0; }
    }
    @@media (max-width: 480px) {
        .cart-section { padding: var(--space-5); }
        .product-left img { width: 64px; height: 64px; }
    }
</style>

<!-- ════════════════════════════════════════════════════
     PAGE HEADER
════════════════════════════════════════════════════ -->
<header class="cart-page-header">
    <span class="cart-page-eyebrow">Mua sắm</span>
    <h1 class="cart-page-title">Giỏ hàng của bạn</h1>
    <div class="cart-page-sep" aria-hidden="true"></div>
</header>

@if (!hasItems)
{
    <!-- EMPTY STATE -->
    <div class="cart-empty" role="status">
        <div class="cart-empty__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
        </div>
        <h2 class="cart-empty__title">Giỏ hàng đang trống</h2>
        <p class="cart-empty__desc">Bạn chưa có sản phẩm nào trong giỏ. Hãy khám phá bộ sưu tập trang sức độc đáo của chúng tôi.</p>
        <a asp-controller="Products" asp-action="Index" class="btn-go-shop">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
            </svg>
            Tiếp tục mua sắm
        </a>
    </div>
}
else
{
    <div class="cart-layout">
        <!-- ══ LEFT: Cart + Form ══ -->
        <div class="cart-main">

            <!-- ── 1. Cart Items ── -->
            <div class="cart-section">
                <div class="section-hd">
                    <div class="section-hd__icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                        </svg>
                    </div>
                    <h2 class="section-hd__title">Sản phẩm đã chọn</h2>
                </div>

                @if (ViewData.ModelState.ContainsKey("PaymentError"))
                {
                    <div class="payment-error-alert" role="alert">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                             fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                        @ViewData.ModelState["PaymentError"]!.Errors[0].ErrorMessage
                    </div>
                }

                <div id="cartItems">
                    @foreach (var item in Model.ShoppingCart.Lines)
                    {
                        <div class="product-item" data-id="@item.Product.ProductID">
                            <input type="checkbox"
                                   class="product-checkbox"
                                   data-product-id="@item.Product.ProductID"
                                   aria-label="Chọn sản phẩm @item.Product.Name"
                                   checked />
                            <div class="product-left">
                                <img src="~/images/@item.Product.ImageUrl"
                                     alt="@item.Product.Name"
                                     loading="lazy" />
                                <div class="product-details">
                                    <div class="product-name">@item.Product.Name</div>
                                    <div class="product-code">Mã: @item.Product.ProductID</div>
                                    <div class="quantity-group" role="group" aria-label="Số lượng @item.Product.Name">
                                        <button type="button" class="quantity-btn" data-action="subtract" aria-label="Giảm số lượng">−</button>
                                        <input type="number"
                                               class="quantity-input"
                                               value="@item.Quantity"
                                               data-product-id="@item.Product.ProductID"
                                               data-price="@item.Product.Price"
                                               min="1"
                                               aria-label="Số lượng" />
                                        <button type="button" class="quantity-btn" data-action="add" aria-label="Tăng số lượng">+</button>
                                    </div>
                                </div>
                            </div>
                            <div class="product-actions">
                                <div class="product-price"
                                     data-product-id="@item.Product.ProductID"
                                     data-base-price="@item.Product.Price"
                                     aria-label="Thành tiền">
                                    @((item.Quantity * item.Product.Price).ToString("N0", cultureVN)) VNĐ
                                </div>
                                <button type="button" class="btn-delete" data-product-id="@item.Product.ProductID" aria-label="Xóa @item.Product.Name">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/>
                                        <path d="M10 11v6"/><path d="M14 11v6"/>
                                        <path d="M9 6V4h6v2"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- ── 2. Customer Info ── -->
            <form method="post" asp-page-handler="Checkout" id="checkoutForm" novalidate>
                @Html.AntiForgeryToken()

                <div class="cart-section">
                    <div class="section-hd">
                        <div class="section-hd__icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>

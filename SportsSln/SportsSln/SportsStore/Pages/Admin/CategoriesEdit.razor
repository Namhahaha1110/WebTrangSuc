@using Microsoft.JSInterop
@page "/admin/categories/edit/{CategoryId:long}"
@inherits OwningComponentBase<IStoreRepository>

<h3 class="mb-3">Chỉnh sửa phân loại</h3>

@if (category == null)
{
    <p class="text-muted">Đang tải dữ liệu...</p>
}
else
{
    <div class="card shadow-sm p-4">
        <EditForm Model="@category" OnValidSubmit="HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label class="form-label fw-bold">Tên phân loại</label>
                <InputText class="form-control" @bind-Value="category.Name" />
            </div>

            <button type="submit" class="btn btn-success me-2">
                <i class="bi bi-save"></i> Cập nhật
            </button>
            <NavLink href="/admin/categories" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </NavLink>
        </EditForm>
    </div>
}

@code {
    [Parameter] public long CategoryId { get; set; }

    public IStoreRepository Repository => Service;
    private Category? category;

    protected override async Task OnInitializedAsync()
    {
        category = await Repository.Categories
            .FirstOrDefaultAsync(c => c.CategoryID == CategoryId);
    }

    private async Task HandleValidSubmit()
    {
        Repository.SaveCategory(category!);
        await JS.InvokeVoidAsync("alert", "✅ Đã cập nhật phân loại thành công!");
        NavigationManager.NavigateTo("/admin/categories");
    }

    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    [Inject] IJSRuntime JS { get; set; } = default!;
}

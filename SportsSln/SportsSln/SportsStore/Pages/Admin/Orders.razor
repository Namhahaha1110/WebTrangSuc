@page "/admin/orders"
@inherits OwningComponentBase<IOrderRepository>
@using OfficeOpenXml
@using OfficeOpenXml.Style
@using System.Linq
@using SportsStore.Pages.Admin
@inject NavigationManager NavigationManager

<div class="container mt-3">
    <h2>Quản lý đơn hàng</h2>
    <button class="btn btn-success mb-3" @onclick="DownloadExcel">
        📥 Xuất Excel
    </button>




    @if (IsLoading)
    {
        <div class="alert alert-info">Đang tải dữ liệu...</div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }
    else
    {
        <div class="btn-group mb-3 order-filter-group" role="group">
            <button type="button"
                    class="btn @(ShowUnshipped ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => ShowUnshipped = true"
                    disabled="@IsLoading">
                📦 Chưa giao (@UnshippedOrders.Count())
            </button>
            <button type="button"
                    class="btn @(!ShowUnshipped ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => ShowUnshipped = false"
                    disabled="@IsLoading">
                ✓ Đã giao (@ShippedOrders.Count())
            </button>
        </div>

        @if (ShowUnshipped)
        {
            <OrderTable TableTitle="Đơn hàng chưa giao"
                        Orders="UnshippedOrders"
                        ButtonLabel="✓ Đánh dấu đã giao"
                        ShowShipped="false"
                        OrderSelected="ShipOrder" />

        }
        else
        {
            <OrderTable TableTitle="Đơn hàng đã giao"
                        Orders="ShippedOrders"
                        ButtonLabel="↶ Quay lại chưa giao"
                        ShowShipped="true"
                        OrderSelected="ResetOrder" />

        }

        <button class="btn btn-info mt-3" @onclick="LoadOrders" disabled="@IsLoading">🔄 Làm mới dữ liệu</button>
    }
</div>

<style>
    @@media (max-width: 767.98px) {
        .order-filter-group {
            width: 100%;
            display: flex;
            flex-direction: column;
        }

        .order-filter-group .btn {
            width: 100%;
        }
    }
</style>

@code {
    public IOrderRepository Repository => Service;
    public IEnumerable<Order> AllOrders { get; set; } = Enumerable.Empty<Order>();
    public IEnumerable<Order> UnshippedOrders { get; set; } = Enumerable.Empty<Order>();
    public IEnumerable<Order> ShippedOrders { get; set; } = Enumerable.Empty<Order>();
    public bool ShowUnshipped { get; set; } = true;

    public bool IsLoading { get; set; } = false;
    public string? ErrorMessage { get; set; } = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    public async Task LoadOrders()
    {
        IsLoading = true;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            await Task.Run(() =>
            {
                AllOrders = Repository.Orders
                    .AsEnumerable() // Force evaluation from DB with all includes
                    .ToList();

                UnshippedOrders = AllOrders.Where(o => !o.Shipped).OrderByDescending(o => o.CreatedDate);
                ShippedOrders = AllOrders.Where(o => o.Shipped).OrderByDescending(o => o.CreatedDate);

                Console.WriteLine($"[v0] Loaded {AllOrders.Count()} orders. Shipped: {ShippedOrders.Count()}, Unshipped: {UnshippedOrders.Count()}");
            });
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Lỗi khi tải dữ liệu: {ex.Message}";
            Console.WriteLine($"[v0] Error loading orders: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
        }

        StateHasChanged();
    }

    public async Task ShipOrder(int id)
    {
        await UpdateOrder(id, true);
    }

    public async Task ResetOrder(int id)
    {
        await UpdateOrder(id, false);
    }

    private async Task UpdateOrder(int id, bool shipValue)
    {
        try
        {
            if (shipValue)
            {
                var order = Repository.Orders.FirstOrDefault(o => o.OrderID == id);
                var isPaymentPending = order != null
                    && (order.Payment == "VNPAY_PENDING" || order.Payment == "BANK_PENDING" || order.Payment == "Bank");
                if (isPaymentPending)
                {
                    ErrorMessage = $"Đơn #{id} đang chờ thanh toán online, chưa thể giao hàng.";
                    StateHasChanged();
                    return;
                }
            }

            await Task.Run(() =>
            {
                Repository.UpdateOrderShippedStatus(id, shipValue);
                Console.WriteLine($"[v0] Order {id} updated to Shipped={shipValue}");
            });

            // Reload after update
            await LoadOrders();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Lỗi khi cập nhật đơn hàng: {ex.Message}";
            Console.WriteLine($"[v0] Error updating order: {ex.Message}");
            StateHasChanged();
        }
    }
    [Inject] IWebHostEnvironment WebHostEnv { get; set; }
    [Inject] IHttpContextAccessor HttpContextAccessor { get; set; }

    public async Task ExportExcel()
    {
        try
        {
            ExcelPackage.LicenseContext = LicenseContext.NonCommercial; // FIX LỖI LICENSE

            var orders = AllOrders.ToList();

            string folder = Path.Combine(WebHostEnv.WebRootPath, "exports");
            if (!Directory.Exists(folder))
                Directory.CreateDirectory(folder);

            string filePath = Path.Combine(folder, $"Orders_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx");

            using (var package = new ExcelPackage())
            {
                var ws = package.Workbook.Worksheets.Add("Orders");

                // Header
                ws.Cells[1, 1].Value = "OrderID";
                ws.Cells[1, 2].Value = "Khách hàng";
                ws.Cells[1, 3].Value = "Điện thoại";
                ws.Cells[1, 4].Value = "Địa chỉ";
                ws.Cells[1, 5].Value = "Tổng tiền";
                ws.Cells[1, 6].Value = "Trạng thái";

                int row = 2;

                foreach (var o in orders)
                {
                    ws.Cells[row, 1].Value = o.OrderID;
                    ws.Cells[row, 2].Value = o.Name;
                    ws.Cells[row, 3].Value = o.Phone;

                    ws.Cells[row, 4].Value =
                        o.DeliveryType == "delivery"
                        ? $"{o.AddressDetail}, {o.Ward}, {o.District}, {o.Province}"
                        : $"{o.Store} ({o.City})";

                    ws.Cells[row, 5].Value = o.TotalPrice;
                    ws.Cells[row, 6].Value = o.Shipped ? "Đã giao" : "Chưa giao";

                    row++;
                }

                ws.Cells.AutoFitColumns();
                package.SaveAs(new FileInfo(filePath));
            }

            var context = HttpContextAccessor.HttpContext;
            var response = context.Response;

            response.ContentType = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet";
            response.Headers.Add("Content-Disposition", $"attachment; filename=orders.xlsx");

            await response.SendFileAsync(filePath);
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Lỗi xuất Excel: {ex.Message}";
        }
    }
    private async Task DownloadExcel()
    {
        NavigationManager.NavigateTo("/api/export/orders", true);
    }

}
